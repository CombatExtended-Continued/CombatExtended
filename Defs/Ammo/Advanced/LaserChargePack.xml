<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<ThingCategoryDef>
		<defName>AmmoLaserChargePack</defName>
		<label>laser charge pack</label>
		<parent>AmmoAdvanced</parent>
		<iconPath>UI/Icons/ThingCategories/CaliberCharge</iconPath>
	</ThingCategoryDef>

	<!-- ==================== AmmoSet ========================== -->

	<!-- ==================== Ammo ========================== -->

	<ThingDef Class="CombatExtended.AmmoDef" Name="LaserChargePackBase" ParentName="SpacerSmallAmmoBase" Abstract="True">
		<description>A universal charge pack for various laser weapons.</description>
		<statBases>
			<Mass>0.008</Mass>
			<Bulk>0.01</Bulk>
		</statBases>
		<tradeTags>
			<li>CE_AutoEnableTrade</li>
		</tradeTags>
		<thingCategories>
			<li>AmmoLaserChargePack</li>
		</thingCategories>
		<stackLimit>5000</stackLimit>
	</ThingDef>

	<ThingDef Class="CombatExtended.AmmoDef" ParentName="LaserChargePackBase">
		<defName>Ammo_LaserChargePack</defName>
		<label>laser charge pack</label>
		<tradeTags>
			<li>CE_AutoEnableCrafting_FabricationBench</li>
		</tradeTags>
		<graphicData>
			<texPath>Things/Ammo/LaserPack</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<ammoClass>Laser</ammoClass>
	</ThingDef>
	
	<ThingDef Class="CombatExtended.AmmoDef" ParentName="LaserChargePackBase">
		<defName>Ammo_LaserChargePack_LP</defName>
		<label>industrial laser pack</label>
		<tradeTags>
			<li>CE_AutoEnableCrafting_TableMachining</li>
		</tradeTags>
		<statBases>
			<Mass>0.080</Mass>
			<Bulk>0.1</Bulk>
		</statBases>
		<description>A bulky, industrial tech charge pack capable of powering various laser weapons. Has lower performance compared to more advanced charge packs.</description>
		<graphicData>
			<texPath>Things/Ammo/LaserPack</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<ammoClass>Laser_LP</ammoClass>
	</ThingDef>

	<!-- ==================== Recipes ========================== -->
	
	<RecipeDef ParentName="GrenadeRecipeBase">
		<defName>MakeAmmo_LaserChargePack_LP</defName>
		<label>make industrial laser charge pack x500</label>
		<description>Craft 500 industrial laser charge pack.</description>
		<jobString>Making industrial laser charge pack.</jobString>
		<researchPrerequisites>
			<li>MicroelectronicsBasics</li>
		</researchPrerequisites>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Plasteel</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>10</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>8</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Plasteel</li>
				<li>Steel</li>
				<li>ComponentIndustrial</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<Ammo_LaserChargePack_LP>500</Ammo_LaserChargePack_LP>
		</products>
		<workAmount>8400</workAmount>
	</RecipeDef>

	<RecipeDef ParentName="ChargeAmmoRecipeBase">
		<defName>MakeAmmo_LaserChargePack</defName>
		<label>make laser charge pack x500</label>
		<description>Craft 500 laser charge pack.</description>
		<jobString>Making laser charge pack.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Plasteel</li>
					</thingDefs>
				</filter>
				<count>8</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>4</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>8</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Plasteel</li>
				<li>Steel</li>
				<li>ComponentIndustrial</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<Ammo_LaserChargePack>500</Ammo_LaserChargePack>
		</products>
		<workAmount>8400</workAmount>
	</RecipeDef>

</Defs>