	<!-- Unique Charge Rifle -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Gun_ChargeRifle_Unique"]/comps</xpath>
		<value>
			<li Class="CombatExtended.CompProperties_AmmoUser">
