<?xml version="1.0" encoding="UTF-8"?>
<Patch>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/WeaponTraitDef[defName="IncendiaryRounds"]/damageDefOverride</xpath>
		<value>
			<extraDamages>
				<li>
					<def>Flame_Secondary_Incendiary</def>
					<amount>2</amount>
				</li>
			</extraDamages>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/WeaponTraitDef[defName="HighPowerRounds"]/statFactors</xpath>
		<value>
			<statFactors>
				<CE_RangedWeapon_RecoilMultiplier>1.2</CE_RangedWeapon_RecoilMultiplier>
			</statFactors>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/WeaponTraitDef[defName="IncendiaryPellets"]/damageDefOverride</xpath>
		<value>
			<extraDamages>
				<li>
					<def>Flame_Secondary_Incendiary</def>
					<amount>1</amount>
				</li>
			</extraDamages>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/WeaponTraitDef[defName="BirdshotPellets"]/statFactors</xpath>
		<value>
			<statFactors>
				<ShotSpread>1.5</ShotSpread>
			</statFactors>
		</value>
	</Operation>

	<Operation Class="PatchOperationRemove">
		<xpath>Defs/WeaponTraitDef[defName="BirdshotPellets"]/statOffsets/RangedWeapon_ArmorPenetrationMultiplier</xpath>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/WeaponTraitDef[defName="BirdshotPellets"]/label</xpath>
		<value>
			<label>wide bore</label>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/WeaponTraitDef[defName="BirdshotPellets"]/description</xpath>
		<value>
			<description>This weapon has a wider bore than normal and has considerably larger spread.</description>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/WeaponTraitDef[defName="ParalyticArrows"]/damageDefOverride</xpath>
		<value>
			<extraDamages>
				<li>
					<def>Nerve</def>
					<amount>1</amount> <!-- Amount shouldn't matter for stun duration -->
				</li>
			</extraDamages>
		</value>
	</Operation>

	<Operation Class="PatchOperationRemove">
		<xpath>Defs/WeaponTraitDef[defName="OversizedRounds"]/additionalStoppingPower</xpath>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/WeaponTraitDef[defName="OversizedRounds"]/statOffsets</xpath>
		<value>
			<RangedWeapon_ArmorPenetrationMultiplier>0.1</RangedWeapon_ArmorPenetrationMultiplier>
		</value>
	</Operation>

</Patch>