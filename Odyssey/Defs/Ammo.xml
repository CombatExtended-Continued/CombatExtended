<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!-- === Ammo Sets === -->

	<CombatExtended.AmmoSetDef>
		<defName>AmmoSet_BeamRepeater</defName>
		<label>laser charge</label>
		<ammoTypes>
			<Ammo_LaserChargePack>Bullet_Laser_BeamRepeater</Ammo_LaserChargePack>
			<Ammo_LaserChargePack_Mech>Bullet_Laser_BeamRepeater_Mech</Ammo_LaserChargePack_Mech>
		</ammoTypes>
	</CombatExtended.AmmoSetDef>

	<!-- === Projectiles === -->

	<ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" ParentName="LaserBulletRed">
		<defName>Bullet_Laser_BeamRepeater</defName>
		<label>laser beam</label>
		<graphicData>
			<color>(255,255,255)</color>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>BeamBypassShields</damageDef>
			<damageAmountBase>8</damageAmountBase>
		</projectile>
	</ThingDef>
	
	<ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" ParentName="LaserBulletRed">
		<defName>Bullet_Laser_BeamRepeater_Mech</defName>
		<label>laser beam</label>
		<graphicData>
			<color>(230,255,230)</color>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>BeamBypassShields</damageDef>
			<damageAmountBase>8</damageAmountBase>
			<spreadMult>0.75</spreadMult>
		</projectile>
	</ThingDef>
	
	<ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" ParentName="LaserBulletRed">
		<defName>Bullet_Laser_Shotgun</defName>
		<label>laser beam</label>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>BeamBypassShields</damageDef>
			<damageAmountBase>9</damageAmountBase>
			<pelletCount>4</pelletCount>
			<armorPenetrationSharp>17.5</armorPenetrationSharp>
			<armorPenetrationBlunt>0.001</armorPenetrationBlunt>
			<spreadMult>12</spreadMult>
			<damageFalloff>false</damageFalloff>
		</projectile>
	</ThingDef>

</Defs>