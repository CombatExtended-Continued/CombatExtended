<Patch>
	<!-- stock bash-->
	<Operation Class="PatchOperationReplace">
		<xpath>
			Defs/ThingDef[
				defName="GW_HOI_ROR_Gun_Accatranfive" or
				defName="GW_HOI_ROR_Gun_VossPattern" or
				defName="GW_HOI_ROR_Gun_PlasmaGun" or
				defName="GW_HOI_ROR_Gun_MeltaGun"
			]/tools
		</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>barrel</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>5</power>
					<cooldownTime>2.02</cooldownTime>
					<armorPenetrationBlunt>1.63</armorPenetrationBlunt>
					<linkedBodyPartsGroup>Barrel</linkedBodyPartsGroup>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>stock</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>8</power>
