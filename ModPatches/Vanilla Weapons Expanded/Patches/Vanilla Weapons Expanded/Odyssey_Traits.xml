<?xml version="1.0" encoding="UTF-8"?>
<Patch>

	<!-- VWE2 Odyssey Traits - Combat Extended Compatibility -->
	<!-- Only applies when Odyssey DLC is loaded -->

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Odyssey</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>

				<!-- ============================================== -->
				<!-- UNIVERSAL TRAITS (WeaponTraitDefs_Universal.xml) -->
				<!-- ============================================== -->

				<!-- VWE_SkeletonizedFrame: Remove AccuracyLong x0.25, add CE stats -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_SkeletonizedFrame"]/statFactors/AccuracyLong</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_SkeletonizedFrame"]/statFactors</xpath>
					<value>
						<ShotSpread>1.5</ShotSpread>
					</value>
				</li>

				<!-- VWE_WeightedStock: Convert to CustomWeaponTraitDef for melee damage override -->
				<li Class="PatchOperationAttributeSet">
					<xpath>Defs/WeaponTraitDef[defName="VWE_WeightedStock"]</xpath>
					<attribute>Class</attribute>
					<value>CombatExtended.CustomWeaponTraitDef</value>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_WeightedStock"]/modExtensions</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_WeightedStock"]</xpath>
					<value>
						<meleeDamageOverride>VWE_StunBlunt</meleeDamageOverride>
					</value>
				</li>

				<!-- VWE_PortedBarrel: Add recoil reduction (realistic for ported barrel) -->
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_PortedBarrel"]/statFactors</xpath>
					<value>
						<CE_RangedWeapon_RecoilMultiplier>0.9</CE_RangedWeapon_RecoilMultiplier>
					</value>
				</li>

				<!-- VWE_IlluminatedSights: Remove all Accuracy, add SightsEfficiency -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_IlluminatedSights"]/statFactors/AccuracyTouch</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_IlluminatedSights"]/statFactors/AccuracyShort</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_IlluminatedSights"]/statFactors/AccuracyMedium</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_IlluminatedSights"]/statFactors/AccuracyLong</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_IlluminatedSights"]/statFactors</xpath>
					<value>
						<SightsEfficiency>1.10</SightsEfficiency>
					</value>
				</li>

				<!-- VWE_MatchTrigger: Remove Accuracy, add SightsEfficiency -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_MatchTrigger"]/statFactors/AccuracyMedium</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_MatchTrigger"]/statFactors/AccuracyLong</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_MatchTrigger"]/statFactors</xpath>
					<value>
						<SightsEfficiency>1.15</SightsEfficiency>
					</value>
				</li>

				<!-- VWE_FireSelector: Convert to CustomWeaponTraitDef for burst count override -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_FireSelector"]/statFactors/AccuracyMedium</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_FireSelector"]/statFactors/AccuracyLong</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_FireSelector"]/statFactors</xpath>
					<value>
						<SightsEfficiency>1.30</SightsEfficiency>
					</value>
				</li>
				<li Class="PatchOperationAttributeSet">
					<xpath>Defs/WeaponTraitDef[defName="VWE_FireSelector"]</xpath>
					<attribute>Class</attribute>
					<value>CombatExtended.CustomWeaponTraitDef</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_FireSelector"]</xpath>
					<value>
						<burstShotCountMultipliers>
							<li>0</li>
						</burstShotCountMultipliers>
					</value>
				</li>

				<!-- VWE_Akimbo: Remove all Accuracy, add CE penalty stats, convert to CustomWeaponTraitDef -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_Akimbo"]/statFactors/AccuracyTouch</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_Akimbo"]/statFactors/AccuracyShort</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_Akimbo"]/statFactors/AccuracyMedium</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_Akimbo"]/statFactors/AccuracyLong</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_Akimbo"]/statFactors</xpath>
					<value>
						<ShotSpread>2.0</ShotSpread>
						<SwayFactor>1.8</SwayFactor>
						<CE_RangedWeapon_RecoilMultiplier>1.5</CE_RangedWeapon_RecoilMultiplier>
						<BurstShotCount>2</BurstShotCount>
						<TicksBetweenBurstShots>0.5</TicksBetweenBurstShots>
					</value>
				</li>
				<li Class="PatchOperationAttributeSet">
					<xpath>Defs/WeaponTraitDef[defName="VWE_Akimbo"]</xpath>
					<attribute>Class</attribute>
					<value>CombatExtended.CustomWeaponTraitDef</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_Akimbo"]</xpath>
					<value>
						<magazineCapacityFactor>2.0</magazineCapacityFactor>
					</value>
				</li>

				<!-- ============================================== -->
				<!-- HEAVY WEAPONS TRAITS (WeaponTraitDefs_HeavyWeapons.xml) -->
				<!-- ============================================== -->

				<!-- VWE_Bipod: REMOVED - CE has built-in bipod system (BipodComp) -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_Bipod"]</xpath>
				</li>

				<!-- VWE_SaturationFeed: Remove Accuracy, add CE penalty stats -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_SaturationFeed"]/statFactors/AccuracyShort</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_SaturationFeed"]/statFactors/AccuracyMedium</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_SaturationFeed"]/statFactors/AccuracyLong</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_SaturationFeed"]/statFactors</xpath>
					<value>
						<ShotSpread>1.4</ShotSpread>
						<SwayFactor>1.5</SwayFactor>
						<CE_RangedWeapon_RecoilMultiplier>1.3</CE_RangedWeapon_RecoilMultiplier>
						<BurstShotCount>2</BurstShotCount>
					</value>
				</li>

				<!-- VWE_ShortStrokePiston: Add CE burst count reduction -->
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_ShortStrokePiston"]/statFactors</xpath>
					<value>
						<BurstShotCount>0.5</BurstShotCount>
					</value>
				</li>

				<!-- ============================================== -->
				<!-- CHARGE WEAPONS TRAITS (WeaponTraitDefs_ChargeWeapons.xml) -->
				<!-- ============================================== -->

				<!-- VWE_VectorCompensator: Homing projectile lost, compensate with accuracy -->
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_VectorCompensator"]/statFactors</xpath>
					<value>
						<ShotSpread>0.1</ShotSpread>
						<SwayFactor>0.1</SwayFactor>
						<SightsEfficiency>1.5</SightsEfficiency>
					</value>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_VectorCompensator"]/modExtensions</xpath>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/WeaponTraitDef[defName="VWE_VectorCompensator"]/description</xpath>
					<value>
						<description>The barrel is lined with micro-magnetic coils that adjust the projectile's trajectory in mid-air. This "smart bullet" system significantly improves accuracy, but requires lighter, smaller projectiles to function. (CE: Homing disabled, accuracy greatly improved instead)</description>
					</value>
				</li>

				<!-- ============================================== -->
				<!-- SNIPER TRAITS (WeaponTraitDefs_Snipers.xml) -->
				<!-- ============================================== -->

				<!-- VWE_StraightPullAction: Remove AccuracyLong, add slight spread penalty -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_StraightPullAction"]/statFactors/AccuracyLong</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_StraightPullAction"]/statFactors</xpath>
					<value>
						<ShotSpread>1.1</ShotSpread>
					</value>
				</li>

				<!-- VWE_AccelerationRail: Remove AccuracyLong, add spread penalty, remove broken modExtension -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_AccelerationRail"]/statFactors/AccuracyLong</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_AccelerationRail"]/statFactors</xpath>
					<value>
						<ShotSpread>1.1</ShotSpread>
					</value>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_AccelerationRail"]/modExtensions</xpath>
				</li>

				<!-- VWE_CantedIronSights: Remove all Accuracy, add compromise SightsEfficiency -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_CantedIronSights"]/statFactors/AccuracyTouch</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_CantedIronSights"]/statFactors/AccuracyShort</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_CantedIronSights"]/statFactors/AccuracyLong</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_CantedIronSights"]/statFactors</xpath>
					<value>
						<SightsEfficiency>0.95</SightsEfficiency>
					</value>
				</li>

				<!-- VWE_FixedTeleLens: Convert to CustomWeaponTraitDef with CE verb overrides -->
				<!-- Key feature: minRange 19.9 (can't be done with stats alone) -->
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_FixedTeleLens"]/statOffsets</xpath>
					<value>
						<SightsEfficiency>0.4</SightsEfficiency>
					</value>
				</li>
				<li Class="PatchOperationAttributeSet">
					<xpath>Defs/WeaponTraitDef[defName="VWE_FixedTeleLens"]</xpath>
					<attribute>Class</attribute>
					<value>CombatExtended.CustomWeaponTraitDef</value>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_FixedTeleLens"]/modExtensions</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_FixedTeleLens"]</xpath>
					<value>
						<verbsOverrideCE>
							<li Class="CombatExtended.VerbPropertiesCE">
								<verbClass>CombatExtended.Verb_ShootCE</verbClass>
								<hasStandardCommand>true</hasStandardCommand>
								<defaultProjectile>Bullet_762x51mmNATO_FMJ</defaultProjectile>
								<warmupTime>3.5</warmupTime>
								<range>44.9</range>
								<minRange>19.9</minRange>
								<soundCast>Shot_SniperRifle</soundCast>
								<soundCastTail>GunTail_Heavy</soundCastTail>
								<muzzleFlashScale>9</muzzleFlashScale>
								<recoilAmount>2.0</recoilAmount>
							</li>
						</verbsOverrideCE>
						<verbsOverridesCE>
							<li>
								<key>VWE_Gun_AntiMaterialRifle_Unique</key>
								<value>
									<li Class="CombatExtended.VerbPropertiesCE">
										<verbClass>CombatExtended.Verb_ShootCE</verbClass>
										<hasStandardCommand>true</hasStandardCommand>
										<defaultProjectile>Bullet_50BMG_FMJ</defaultProjectile>
										<warmupTime>5</warmupTime>
										<range>44.9</range>
										<minRange>19.9</minRange>
										<soundCast>VWE_Shot_AntiMaterialRifle</soundCast>
										<soundCastTail>GunTail_Heavy</soundCastTail>
										<muzzleFlashScale>9</muzzleFlashScale>
										<recoilAmount>2.5</recoilAmount>
									</li>
								</value>
							</li>
							<li>
								<key>VWE_Gun_MarksmanRifle_Unique</key>
								<value>
									<li Class="CombatExtended.VerbPropertiesCE">
										<verbClass>CombatExtended.Verb_ShootCE</verbClass>
										<hasStandardCommand>true</hasStandardCommand>
										<defaultProjectile>Bullet_762x54mmR_FMJ</defaultProjectile>
										<warmupTime>2.166666</warmupTime>
										<range>42.9</range>
										<minRange>19.9</minRange>
										<soundCast>VWE_Shot_MarksmanRifle</soundCast>
										<soundCastTail>GunTail_Heavy</soundCastTail>
										<muzzleFlashScale>9</muzzleFlashScale>
										<recoilAmount>1.94</recoilAmount>
									</li>
								</value>
							</li>
						</verbsOverridesCE>
					</value>
				</li>

				<!-- ============================================== -->
				<!-- REVOLVER TRAITS (WeaponTraitDefs_Revolvers.xml) -->
				<!-- ============================================== -->

				<!-- VWE_RecoilOpMechanism: Convert to CustomWeaponTraitDef with CE verb overrides -->
				<!-- Key feature: 3-round burst with per-weapon tuning -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_RecoilOpMechanism"]/statFactors/AccuracyMedium</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_RecoilOpMechanism"]/statFactors/AccuracyLong</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_RecoilOpMechanism"]/statFactors</xpath>
					<value>
						<ShotSpread>1.6</ShotSpread>
						<SwayFactor>1.8</SwayFactor>
						<CE_RangedWeapon_RecoilMultiplier>1.5</CE_RangedWeapon_RecoilMultiplier>
					</value>
				</li>
				<li Class="PatchOperationAttributeSet">
					<xpath>Defs/WeaponTraitDef[defName="VWE_RecoilOpMechanism"]</xpath>
					<attribute>Class</attribute>
					<value>CombatExtended.CustomWeaponTraitDef</value>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_RecoilOpMechanism"]/modExtensions</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_RecoilOpMechanism"]</xpath>
					<value>
						<verbsOverrideCE>
							<li Class="CombatExtended.VerbPropertiesCE">
								<verbClass>CombatExtended.Verb_ShootCE</verbClass>
								<hasStandardCommand>true</hasStandardCommand>
								<defaultProjectile>Bullet_44Magnum_FMJ</defaultProjectile>
								<warmupTime>0.3</warmupTime>
								<range>25.9</range>
								<soundCast>Shot_Revolver</soundCast>
								<soundCastTail>GunTail_Light</soundCastTail>
								<muzzleFlashScale>9</muzzleFlashScale>
								<ticksBetweenBurstShots>10</ticksBetweenBurstShots>
								<burstShotCount>3</burstShotCount>
								<recoilAmount>2.5</recoilAmount>
							</li>
						</verbsOverrideCE>
						<verbsOverridesCE>
							<li>
								<key>VWE_Gun_HandCannon_Unique</key>
								<value>
									<li Class="CombatExtended.VerbPropertiesCE">
										<verbClass>CombatExtended.Verb_ShootCE</verbClass>
										<hasStandardCommand>true</hasStandardCommand>
										<defaultProjectile>Bullet_460SWMagnum_FMJ</defaultProjectile>
										<warmupTime>0.366666</warmupTime>
										<range>23.9</range>
										<soundCast>VWE_Shot_Handcannon</soundCast>
										<soundCastTail>GunTail_Medium</soundCastTail>
										<muzzleFlashScale>9</muzzleFlashScale>
										<ticksBetweenBurstShots>15</ticksBetweenBurstShots>
										<burstShotCount>3</burstShotCount>
										<recoilAmount>2.5</recoilAmount>
									</li>
								</value>
							</li>
						</verbsOverridesCE>
					</value>
				</li>

				<!-- VWE_BuntlineBarrel: Remove AccuracyLong, add CE stats for long barrel -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_BuntlineBarrel"]/statFactors/AccuracyLong</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_BuntlineBarrel"]/statFactors</xpath>
					<value>
						<SightsEfficiency>1.15</SightsEfficiency>
						<ShotSpread>0.9</ShotSpread>
						<Bulk>1.15</Bulk>
					</value>
				</li>

				<!-- VWE_SnakeShotLoads: Remove Accuracy, add CE close-range pattern -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_SnakeShotLoads"]/statFactors/AccuracyTouch</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_SnakeShotLoads"]/statFactors/AccuracyShort</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_SnakeShotLoads"]/statFactors</xpath>
					<value>
						<ShotSpread>1.3</ShotSpread>
					</value>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_SnakeShotLoads"]/modExtensions</xpath>
				</li>

				<!-- VWE_TopBreakAction: Add CE reload speed bonus -->
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_TopBreakAction"]/statOffsets</xpath>
					<value>
						<CE_RangedWeapon_ReloadFactor>-0.15</CE_RangedWeapon_ReloadFactor>
					</value>
				</li>

				<!-- ============================================== -->
				<!-- BOW TRAITS (WeaponTraitDefs_Bow.xml) -->
				<!-- ============================================== -->

				<!-- VWE_PitchSoakedTips: Convert damageDefOverride to extraDamages.
				     No <chance> needed — Flame_Secondary_Incendiary DamageDef has built-in
				     30% ignite curve via igniteChanceByTargetFlammability. -->
				<li Class="PatchOperationReplace">
					<xpath>Defs/WeaponTraitDef[defName="VWE_PitchSoakedTips"]/damageDefOverride</xpath>
					<value>
						<extraDamages>
							<li>
								<def>Flame_Secondary_Incendiary</def>
								<amount>2</amount>
							</li>
						</extraDamages>
					</value>
				</li>

				<!-- VWE_WhisperFletching: Remove Accuracy, add SightsEfficiency -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_WhisperFletching"]/statFactors/AccuracyMedium</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_WhisperFletching"]/statFactors/AccuracyLong</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_WhisperFletching"]/statFactors</xpath>
					<value>
						<SightsEfficiency>1.08</SightsEfficiency>
					</value>
				</li>

				<!-- VWE_BarbedHeads: Remove additionalStoppingPower, add pen buff -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_BarbedHeads"]/additionalStoppingPower</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_BarbedHeads"]/statOffsets</xpath>
					<value>
						<RangedWeapon_ArmorPenetrationMultiplier>0.15</RangedWeapon_ArmorPenetrationMultiplier>
					</value>
				</li>

				<!-- VWE_TwinNock: Remove all Accuracy, add CE spread/sway penalties, convert to CustomWeaponTraitDef -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_TwinNock"]/statFactors/AccuracyTouch</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_TwinNock"]/statFactors/AccuracyShort</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_TwinNock"]/statFactors/AccuracyMedium</xpath>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/WeaponTraitDef[defName="VWE_TwinNock"]/statFactors/AccuracyLong</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_TwinNock"]/statFactors</xpath>
					<value>
						<ShotSpread>1.4</ShotSpread>
						<SwayFactor>1.3</SwayFactor>
						<BurstShotCount>2</BurstShotCount>
					</value>
				</li>
				<li Class="PatchOperationAttributeSet">
					<xpath>Defs/WeaponTraitDef[defName="VWE_TwinNock"]</xpath>
					<attribute>Class</attribute>
					<value>CombatExtended.CustomWeaponTraitDef</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/WeaponTraitDef[defName="VWE_TwinNock"]</xpath>
					<value>
						<magazineCapacityFactor>2.0</magazineCapacityFactor>
					</value>
				</li>

				<!-- VWE_BluntHeads: Remove additionalStoppingPower, add damage buff -->
				<li Class="PatchOperationRemove">
