<?xml version="1.0" encoding="UTF-8"?>
<Patch>
    <!-- ============================ Uniform ============================ -->
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[
            defName="OoaraiUniform" or
            defName="AnzioUniform" or
            defName="BCFreedomUniform" or
            defName="KuromorimineUniform" or
            defName="PravdaUniform-K" or
            defName="PravdaUniform-N" or
            defName="SenshaDoUniform" or
            defName="StarsUniversityUniform" or
            defName="StGlorianaUniform"
            ]/statBases</xpath>
        <value>
            <Bulk>10</Bulk>
            <WornBulk>5</WornBulk>
            <Flammability>0.50</Flammability>
        </value>
    </Operation>

    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[
            defName="OoaraiUniform" or
            defName="AnzioUniform" or
            defName="BCFreedomUniform" or
            defName="KuromorimineUniform" or
            defName="PravdaUniform-K" or
            defName="PravdaUniform-N" or
            defName="SenshaDoUniform" or
            defName="StarsUniversityUniform" or
            defName="StGlorianaUniform"
            ]/equippedStatOffsets</xpath>
        <value>
            <ToxicEnvironmentResistance MayRequire="Ludeon.RimWorld.Biotech">1.0</ToxicEnvironmentResistance>
            <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">1.0</VacuumResistance>
        </value>
    </Operation>

    <!--Ooarai Uniform-->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="OoaraiUniform"]/statBases/ArmorRating_Sharp</xpath>
        <value>
            <ArmorRating_Sharp>12.0</ArmorRating_Sharp>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="OoaraiUniform"]/statBases/ArmorRating_Blunt</xpath>
        <value>
            <ArmorRating_Blunt>5.04</ArmorRating_Blunt>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="OoaraiUniform"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
        <value>
            <ShootingAccuracyPawn>0.12</ShootingAccuracyPawn>
            <AimingAccuracy>0.06</AimingAccuracy>
        </value>
    </Operation>

    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="OoaraiUniform"]/equippedStatOffsets</xpath>
        <value>
            <Flammability>-1.0</Flammability>
            <Suppressability>-0.1</Suppressability>
            <CarryBulk>10</CarryBulk>
			<ReloadSpeed>0.05</ReloadSpeed>
            <CarryWeight>2</CarryWeight>
