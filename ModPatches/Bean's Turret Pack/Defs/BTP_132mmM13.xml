			<flyOverhead>false</flyOverhead>
			<gravityFactor>10</gravityFactor>
		</projectile>
		<comps>
			<li Class="CombatExtended.CompProperties_Fragments">
				<fragments>
					<Fragment_Large>7</Fragment_Large>
					<Fragment_Small>11</Fragment_Small>
				</fragments>
			</li>
