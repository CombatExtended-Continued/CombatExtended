<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ===== Clarent ===== -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="FGO_Clarent"]/statBases</xpath>
		<value>
			<Bulk>10</Bulk>
			<MeleeCounterParryBonus>0.50</MeleeCounterParryBonus>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="FGO_Clarent"]</xpath>
		<value>
			<equippedStatOffsets>
				<MeleeCritChance>1.50</MeleeCritChance>
				<MeleeParryChance>0.60</MeleeParryChance>
			</equippedStatOffsets>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="FGO_Clarent"]/tools</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>handle</label>
					<capacities>
						<li>Poke</li>
					</capacities>
					<armorPenetrationBlunt>0.50</armorPenetrationBlunt>
					<power>2</power>
					<cooldownTime>1.50</cooldownTime>
					<chanceFactor>0.10</chanceFactor>
					<linkedBodyPartsGroup>Handle</linkedBodyPartsGroup>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>point</label>
					<capacities>
						<li>Stab</li>
					</capacities>
					<armorPenetrationBlunt>1.50</armorPenetrationBlunt>
					<armorPenetrationSharp>25</armorPenetrationSharp>
					<power>20</power>
					<cooldownTime>0.94</cooldownTime>
					<linkedBodyPartsGroup>Point</linkedBodyPartsGroup>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>edge</label>
					<capacities>
						<li>Cut</li>
					</capacities>
					<armorPenetrationBlunt>3</armorPenetrationBlunt>
					<armorPenetrationSharp>20</armorPenetrationSharp>
					<power>35</power>
					<cooldownTime>0.83</cooldownTime>
					<linkedBodyPartsGroup>Edge</linkedBodyPartsGroup>
				</li>
			</tools>
		</value>
	</Operation>
	
</Patch>