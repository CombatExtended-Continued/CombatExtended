<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<!-- None of the creatures here are particularly intelligent so they can't parry -->
	<!-- Equation for the specific armor values were provided by ViralReaction -->
	
	<!-- ========== Spliceling ========== -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VQEA_Spliceling"]/statBases</xpath>
		<value>
			<ArmorRating_Sharp>1.2</ArmorRating_Sharp>
			<ArmorRating_Blunt>2.7</ArmorRating_Blunt>
		</value>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VQEA_Splicefiend"]/comps</xpath>
		<value>
			<li Class="CombatExtended.CompProperties_ArmorDurability">
				<Durability>600</Durability>
				<Regenerates>false</Regenerates>
				<MinArmorPct>0.1</MinArmorPct>
			</li>
		</value>
	</Operation>

	<!-- Mostly human mutated, so tools are similar to the human tools -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="VQEA_Spliceling"]/tools</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>left mutated fist</label>
					<labelNoLocation>mutated fist</labelNoLocation>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>1</power>
					<armorPenetrationBlunt>0.5</armorPenetrationBlunt>
					<cooldownTime>1.25</cooldownTime>
					<linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>flesh club</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>5</power>
					<armorPenetrationBlunt>3.6</armorPenetrationBlunt>
					<cooldownTime>1.5</cooldownTime>
					<linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>head</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>5</power>
					<armorPenetrationBlunt>1.2</armorPenetrationBlunt>
					<cooldownTime>2</cooldownTime>
					<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
					<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
					<chanceFactor>0.1</chanceFactor>
				</li>
			</tools>
		</value>
	</Operation>

