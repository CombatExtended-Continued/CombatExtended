					<label>left swollen arm</label>
					<labelNoLocation>swollen arm</labelNoLocation>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>8</power>
					<armorPenetrationBlunt>1.2</armorPenetrationBlunt>
					<cooldownTime>2.6</cooldownTime>
