	<!-- ========== Splicefiend ========== -->
	
	<!-- This one is basically a tank from Left 4 Dead that feels no pain, so some okay armor makes sense -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VQEA_Splicefiend"]/statBases</xpath>
		<value>
			<ArmorRating_Sharp>8.4</ArmorRating_Sharp>
			<ArmorRating_Blunt>26.9</ArmorRating_Blunt>
		</value>
	</Operation>

