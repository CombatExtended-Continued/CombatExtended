<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- =============== Mech Weapons =============== -->
	<!-- === Ammo Sets === -->
	<!-- A part of this weapon's description reads ''It fires dense slugs at incredible velocities, capable of destroying even heavily armored gravships.'' so I've made it a relatively strong railgun weapon and tweaked its warmup and cooldown stats accordingly -->

	<CombatExtended.AmmoSetDef>
		<defName>AmmoSet_VGE_MassLance</defName>
		<label>12mm Railgun</label>
		<ammoTypes>
			<Ammo_12mmRailgun_Sabot>Bullet_VGE_MassLance</Ammo_12mmRailgun_Sabot>
		</ammoTypes>
	</CombatExtended.AmmoSetDef>

	<!-- === Projectiles === -->

	<ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" ParentName="LaserBulletYellow">
		<defName>Bullet_VGE_MassLance</defName>
		<label>mass lance shot</label>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<isInstant>true</isInstant>
			<damageFalloff>False</damageFalloff>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>36</damageAmountBase>
			<armorPenetrationSharp>86.4</armorPenetrationSharp>
			<armorPenetrationBlunt>381</armorPenetrationBlunt>
		</projectile>
	</ThingDef>

	<!-- =============== Artillery Weapons =============== -->

	<!-- <ThingCategoryDef>
		<defName>Ammo155mmHowitzerShells</defName>
		<label>155mm Howitzer shell</label>
		<parent>AmmoShells</parent>
		<iconPath>UI/Icons/ThingCategories/CaliberCannon</iconPath>
	</ThingCategoryDef> -->

	<!-- === GaussGun === -->

	<CombatExtended.AmmoSetDef>
		<defName>AmmoSet_VGE_Bullet_GaussGun</defName>
		<label>VGE_Bullet_GaussGun</label>
		<ammoTypes>
			<Ammo_Bullet_GaussGun_CE>VGE_Bullet_GaussGun_CE</Ammo_Bullet_GaussGun_CE>
		</ammoTypes>
	</CombatExtended.AmmoSetDef>

	<ThingDef Class="CombatExtended.AmmoDef" ParentName="HeavyAmmoBase">
		<description>Large cannon shell used by howitzers.</description>
		<thingCategories>
			<li>Ammo155mmHowitzerShells</li>
		</thingCategories>
		<stackLimit>25</stackLimit>
		<tradeTags>
			<li>CE_AutoEnableTrade</li>
			<li>CE_AutoEnableCrafting_TableMachining</li>
		</tradeTags>
		<statBases>
			<MaxHitPoints>300</MaxHitPoints>
			<Mass>46.7</Mass>
			<Bulk>47.67</Bulk>
		</statBases>
		<cookOffFlashScale>40</cookOffFlashScale>
		<cookOffSound>MortarBomb_Explode</cookOffSound>

		<defName>Ammo_Bullet_GaussGun_CE</defName>
		<label>VGE_Bullet_GaussGun</label>
		<graphicData>
			<texPath>Things/Ammo/Cannon/Howitzer/HE</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<ammoClass>GrenadeHE</ammoClass>
		<detonateProjectile>VGE_Bullet_GaussGun_CE</detonateProjectile>
	</ThingDef>

  	<ThingDef ParentName="BaseBulletCE">
        <defName>VGE_Bullet_GaussGun_CE</defName>
        <label>Gauss gun shot</label>
        <graphicData>
            <texPath>Things/Projectiles/GaussShot_VerySmall</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>TransparentPostLight</shaderType>
        </graphicData>
		<thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
			<trajectoryWorker>CombatExtended.Compatibility.VGECompat.DirectOverheadTrajectoryWorker</trajectoryWorker>
            <damageDef>Bomb</damageDef>
            <damageAmountBase>40</damageAmountBase>
            <armorPenetrationBase>0.15</armorPenetrationBase>
            <speed>115</speed>
            <explosionRadius>3.9</explosionRadius>
            <flyOverhead>true</flyOverhead>
			<dropsCasings>false</dropsCasings>
            <stoppingPower>2</stoppingPower>
			<gravityFactor>10</gravityFactor>
			<shellingProps>
				<tilesPerTick>0.05</tilesPerTick>
				<range>16</range> <!-- based on VanillaGravshipExpanded.CompProperties_WorldArtillery.worldMapAttackRange -->
				<damage>0.1</damage>
			</shellingProps>
        </projectile>
    </ThingDef>

	<RecipeDef ParentName="ArtilleryAmmoRecipeBase">
		<defName>MakeAmmo_Bullet_GaussGun_CE</defName>
		<label>make VGE_Bullet_GaussGun</label>
		<description>Craft a VGE_Bullet_GaussGun.</description>
		<jobString>Making VGE_Bullet_GaussGun.</jobString>
		<researchPrerequisite Inherit="False" />
        <researchPrerequisites>
            <li>VGE_GravshipWeaponry</li>
        </researchPrerequisites>
		<workAmount>17400</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>94</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>FSX</li>
					</thingDefs>
				</filter>
				<count>17</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Steel</li>
				<li>ComponentIndustrial</li>
				<li>FSX</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<Ammo_Bullet_GaussGun_CE>1</Ammo_Bullet_GaussGun_CE>
		</products>
	</RecipeDef>

	<!-- === JavelinPod === -->

	<CombatExtended.AmmoSetDef>
		<defName>AmmoSet_VGE_Bullet_JavelinPod</defName>
		<label>VGE_Bullet_JavelinPod</label>
		<ammoTypes>
			<Ammo_Bullet_JavelinPod_CE>VGE_Bullet_JavelinPod_CE</Ammo_Bullet_JavelinPod_CE>
		</ammoTypes>
	</CombatExtended.AmmoSetDef>

	<ThingDef Class="CombatExtended.AmmoDef" ParentName="HeavyAmmoBase">
		<description>Large cannon shell used by howitzers.</description>
		<thingCategories>
			<li>Ammo155mmHowitzerShells</li>
		</thingCategories>
		<stackLimit>25</stackLimit>
		<tradeTags>
			<li>CE_AutoEnableTrade</li>
			<li>CE_AutoEnableCrafting_TableMachining</li>
		</tradeTags>
		<statBases>
			<MaxHitPoints>300</MaxHitPoints>
			<Mass>46.7</Mass>
			<Bulk>47.67</Bulk>
		</statBases>
		<cookOffFlashScale>40</cookOffFlashScale>
		<cookOffSound>MortarBomb_Explode</cookOffSound>

		<defName>Ammo_Bullet_JavelinPod_CE</defName>
		<label>VGE_Bullet_JavelinPod</label>
		<graphicData>
			<texPath>Things/Ammo/Rocket/70mmAPKWS</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
			<drawSize>0.70</drawSize>
		</graphicData>
		<ammoClass>GrenadeHE</ammoClass>
		<detonateProjectile>VGE_Bullet_JavelinPod_CE</detonateProjectile>
	</ThingDef>

  	<ThingDef ParentName="BaseBulletCE">
        <defName>VGE_Bullet_JavelinPod_CE</defName>
        <label>Javelin rocket</label>
        <graphicData>
            <texPath>Things/Projectiles/Rocket_Javelin</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>TransparentPostLight</shaderType>
            <drawSize>(2,2)</drawSize>
        </graphicData>
		<thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageDef>Bomb</damageDef>
 			<damageAmountBase>24</damageAmountBase>
            <armorPenetrationBase>0.1</armorPenetrationBase>
			<speed>0</speed>
            <explosionRadius>2.9</explosionRadius>
            <flyOverhead>true</flyOverhead>
            <stoppingPower>0.5</stoppingPower>
            <soundImpact>BulletImpact_Metal</soundImpact>
            <soundExplode>MortarBomb_Explode</soundExplode>
            <soundAmbient>MortarRound_Ambient</soundAmbient>
			<dropsCasings>false</dropsCasings>
			<gravityFactor>5</gravityFactor>
			<shellingProps>
				<iconPath>Things/Projectiles/Rocket_Javelin</iconPath>
				<tilesPerTick>0.05</tilesPerTick>
				<range>16</range> <!-- based on VanillaGravshipExpanded.CompProperties_WorldArtillery.worldMapAttackRange -->
				<damage>0.1</damage>
			</shellingProps>
        </projectile>
    </ThingDef>

