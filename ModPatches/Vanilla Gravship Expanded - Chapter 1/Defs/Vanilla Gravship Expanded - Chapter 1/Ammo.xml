<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- =============== Mech Weapons =============== -->
	<!-- === Ammo Sets === -->
	<!-- A part of this weapon's description reads ''It fires dense slugs at incredible velocities, capable of destroying even heavily armored gravships.'' so I've made it a relatively strong railgun weapon and tweaked its warmup and cooldown stats accordingly -->

	<CombatExtended.AmmoSetDef>
		<defName>AmmoSet_VGE_MassLance</defName>
		<label>12mm Railgun</label>
		<ammoTypes>
			<Ammo_12mmRailgun_Sabot>Bullet_VGE_MassLance</Ammo_12mmRailgun_Sabot>
		</ammoTypes>
	</CombatExtended.AmmoSetDef>

	<!-- === Projectiles === -->

	<ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" ParentName="LaserBulletYellow">
		<defName>Bullet_VGE_MassLance</defName>
		<label>mass lance shot</label>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<isInstant>true</isInstant>
			<damageFalloff>False</damageFalloff>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>36</damageAmountBase>
			<armorPenetrationSharp>86.4</armorPenetrationSharp>
			<armorPenetrationBlunt>381</armorPenetrationBlunt>
		</projectile>
	</ThingDef>

	<!-- =============== Artillery Weapons =============== -->
	<!-- ====== GaussGun ====== -->
	<!-- === Ammo Sets === -->

	<CombatExtended.AmmoSetDef>
		<defName>AmmoSet_155mmHowitzerShell_GaussGun</defName>
		<label>155mm howitzer shells</label>
		<ammoTypes>
			<Ammo_155mmHowitzerShell_HE>VGE_Bullet_GaussGun_CE_HE</Ammo_155mmHowitzerShell_HE>
			<Ammo_155mmHowitzerShell_HE_HFuzed>VGE_Bullet_GaussGun_CE_HE_HFuzed</Ammo_155mmHowitzerShell_HE_HFuzed>
			<Ammo_155mmHowitzerShell_Incendiary>VGE_Bullet_GaussGun_CE_Incendiary</Ammo_155mmHowitzerShell_Incendiary>
			<Ammo_155mmHowitzerShell_EMP>VGE_Bullet_GaussGun_CE_EMP</Ammo_155mmHowitzerShell_EMP>
			<Ammo_155mmHowitzerShell_Smoke>VGE_Bullet_GaussGun_CE_Smoke</Ammo_155mmHowitzerShell_Smoke>
		</ammoTypes>
	</CombatExtended.AmmoSetDef>

	<!-- === Projectiles === -->

	<ThingDef Name="Base155mmHowitzerShell_GaussGun" ParentName="BaseExplosiveBullet" Abstract="true">
		<thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
		<graphicData>
			<shaderType>TransparentPostLight</shaderType>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<trajectoryWorker>CombatExtended.Compatibility.VGECompat.DirectOverheadTrajectoryWorker</trajectoryWorker>
            <speed>115</speed>
			<soundExplode>MortarBomb_Explode</soundExplode>
			<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
			<soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
			<soundAmbient>MortarRound_Ambient</soundAmbient>
			<flyOverhead>true</flyOverhead>
			<dropsCasings>false</dropsCasings>
			<gravityFactor>10</gravityFactor>
			<shellingProps>
				<tilesPerTick>0.05</tilesPerTick>
				<range>16</range> <!-- based on VanillaGravshipExpanded.CompProperties_WorldArtillery.worldMapAttackRange -->
				<arrivedAtSameProps>true</arrivedAtSameProps>
			</shellingProps>
		</projectile>
		<comps>
			<li Class="CombatExtended.CompProperties_ProjectileFleck">
				<FleckDatas>
					<li>
						<fleck>Fleck_CERocketSmokeTrail</fleck>
						<emissionsPerTick>1</emissionsPerTick>
						<rotation>0~360</rotation>
						<flecksPerEmission>1</flecksPerEmission>
					</li>
					<li>
						<fleck>Fleck_CERocketSmoke</fleck>
						<emissionsPerTick>5</emissionsPerTick>
						<rotation>0~360</rotation>
						<flecksPerEmission>2</flecksPerEmission>
						<cutoffTickRange>25~60</cutoffTickRange>
					</li>			
				</FleckDatas>
			</li>
		</comps>
	</ThingDef>

	<ThingDef ParentName="Base155mmHowitzerShell_GaussGun">
		<defName>VGE_Bullet_GaussGun_CE_HE</defName>
		<label>155mm Howitzer shell (HE)</label>
		<graphicData>
			<texPath>Things/Projectile/Cannon/Howitzer/HE</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>Bomb</damageDef>
			<damageAmountBase>546</damageAmountBase>
			<explosionRadius>5.5</explosionRadius>
			<soundExplode>MortarBomb_Explode</soundExplode>
			<applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
			<shellingProps>
				<damage>0.33</damage>
			</shellingProps>
			<preExplosionSpawnSingleThingDef>CraterMedium</preExplosionSpawnSingleThingDef>
		</projectile>
		<comps>
			<li Class="CombatExtended.CompProperties_Fragments">
				<fragments>
					<Fragment_Large>40</Fragment_Large>
					<Fragment_Small>80</Fragment_Small>
				</fragments>
			</li>
		</comps>
	</ThingDef>

	<ThingDef ParentName="Base155mmHowitzerShell_GaussGun">
		<defName>VGE_Bullet_GaussGun_CE_HE_HFuzed</defName>
		<label>155mm Howitzer shell (Airburst)</label>
		<thingClass>CombatExtended.ProjectileCE_HeightFuse</thingClass>
		<graphicData>
			<texPath>Things/Projectile/Cannon/Howitzer/AB</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>Smoke</damageDef>
			<damageAmountBase>0</damageAmountBase>
			<explosionRadius>5.5</explosionRadius>
			<soundExplode>MortarBomb_Explode</soundExplode>
			<applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
			<aimHeightOffset>12</aimHeightOffset>
			<shellingProps>
				<damage>0.33</damage>
			</shellingProps>
		</projectile>
		<comps>
			<li Class="CombatExtended.CompProperties_Fragments">
				<fragments>
					<Fragment_Large>40</Fragment_Large>
					<Fragment_Small>80</Fragment_Small>
				</fragments>
				<fragAngleRange>-90~-40</fragAngleRange>
			</li>
		</comps>
	</ThingDef>

	<ThingDef ParentName="Base155mmHowitzerShell_GaussGun">
		<defName>VGE_Bullet_GaussGun_CE_Incendiary</defName>
		<label>155mm Howitzer shell (Incendiary)</label>
		<graphicData>
			<texPath>Things/Projectile/Cannon/Howitzer/INC</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>PrometheumFlame</damageDef>
			<damageAmountBase>31</damageAmountBase>
			<explosionRadius>11.5</explosionRadius>
			<preExplosionSpawnThingDef>FilthPrometheum</preExplosionSpawnThingDef>
			<preExplosionSpawnChance>0.20</preExplosionSpawnChance>
			<soundExplode>MortarIncendiary_Explode</soundExplode>
			<shellingProps>
				<damage>0.33</damage>
			</shellingProps>
			<preExplosionSpawnSingleThingDef>Filth_BlastMark</preExplosionSpawnSingleThingDef>
		</projectile>
		<comps>
			<li Class="CombatExtended.CompProperties_ExplosiveCE">
				<damageAmountBase>253</damageAmountBase>
				<explosiveDamageType>Thermobaric</explosiveDamageType>
				<explosiveRadius>4</explosiveRadius>
				<applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
			</li>
		</comps>
	</ThingDef>

	<ThingDef ParentName="Base155mmHowitzerShell_GaussGun">
		<defName>VGE_Bullet_GaussGun_CE_EMP</defName>
		<label>155mm Howitzer shell (EMP)</label>
		<graphicData>
			<texPath>Things/Projectile/Cannon/Howitzer/EMP</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>EMP</damageDef>
			<damageAmountBase>452</damageAmountBase>
			<explosionRadius>9.5</explosionRadius>
			<shellingProps>
				<damage>0.23</damage>
			</shellingProps>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="Base155mmHowitzerShell_GaussGun">
		<defName>VGE_Bullet_GaussGun_CE_Smoke</defName>
		<label>155mm Howitzer shell (Smoke)</label>
		<graphicData>
			<texPath>Things/Projectile/Cannon/Howitzer/SMK</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>Smoke</damageDef>
			<suppressionFactor>0.0</suppressionFactor>
			<dangerFactor>0.0</dangerFactor>
			<explosionRadius>10.5</explosionRadius>
			<flyOverhead>true</flyOverhead>
			<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
			<soundExplode>Explosion_EMP</soundExplode>
			<soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
			<soundAmbient>MortarRound_Ambient</soundAmbient>
			<postExplosionGasType>BlindSmoke</postExplosionGasType>
			<preExplosionSpawnChance>1</preExplosionSpawnChance>
			<applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
			<explosionEffect>ExtinguisherExplosion</explosionEffect>
		</projectile>
	</ThingDef>

	<!-- ====== JavelinPod ====== -->

	<ThingCategoryDef>
		<defName>AmmoGravshipRocket</defName>
		<label />
		<parent>AmmoRockets</parent>
		<iconPath>UI/Icons/ThingCategories/CaliberRocket</iconPath>
	</ThingCategoryDef>

	<!-- === Ammo Sets === -->

	<CombatExtended.AmmoSetDef>
		<defName>AmmoSet_VGE_Bullet_JavelinPod</defName>
		<label>Gravship javelin missile</label>
		<ammoTypes>
			<Ammo_Bullet_JavelinPod_CE>VGE_Bullet_JavelinPod_CE</Ammo_Bullet_JavelinPod_CE>
		</ammoTypes>
	</CombatExtended.AmmoSetDef>

	<!-- === Ammo === -->

	<ThingDef Class="CombatExtended.AmmoDef" Name="VGERocketBase" ParentName="SpacerMediumAmmoBase" Abstract="True">
		<description>An unguided javelin missile equipped with an explosive warhead and a contact fuse. Propelled with Gravship fuel. Need to be fueled from its turret.</description>
		<statBases>
			<MaxHitPoints>150</MaxHitPoints>
			<Mass>4.5</Mass>
			<Bulk>7.07</Bulk>
		</statBases>
		<tradeTags>
			<li>CE_AutoEnableTrade</li>
			<li>CE_AutoEnableCrafting_TableMachining</li>
		</tradeTags>
		<thingCategories>
			<li>AmmoGravshipRocket</li>
		</thingCategories>
		<stackLimit>25</stackLimit>
	</ThingDef>

	<ThingDef Class="CombatExtended.AmmoDef" ParentName="VGERocketBase">
		<defName>Ammo_Bullet_JavelinPod_CE</defName>
		<label>Gravship javelin (HE)</label>
		<graphicData>
			<texPath>Things/Ammo/Rocket/70mmAPKWS</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
			<drawSize>0.70</drawSize>
		</graphicData>
	</ThingDef>

	<!-- === Projectile === -->

	<ThingDef Name="BaseVGERocket" ParentName="BaseExplosiveBullet" Abstract="true">
		<graphicData>
            <shaderType>TransparentPostLight</shaderType>
        </graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<speed>0</speed>
			<soundAmbient>MortarRound_Ambient</soundAmbient>
			<soundImpact>BulletImpact_Metal</soundImpact>
            <soundExplode>MortarBomb_Explode</soundExplode>
			<soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
			<dropsCasings>false</dropsCasings>
			<flyOverhead>true</flyOverhead>
			<gravityFactor>5</gravityFactor>
			<shellingProps>
				<iconPath>Things/Projectiles/Rocket_Javelin</iconPath>
				<tilesPerTick>0.05</tilesPerTick>
				<range>16</range> <!-- based on VanillaGravshipExpanded.CompProperties_WorldArtillery.worldMapAttackRange -->
				<damage>0.1</damage>
			</shellingProps>
		</projectile>
		<comps>
			<li Class="CombatExtended.CompProperties_ProjectileFleck">
				<FleckDatas>
					<li>
						<fleck>Fleck_CERocketFlame</fleck>
						<emissionsPerTick>7</emissionsPerTick>
						<flecksPerEmission>3</flecksPerEmission>
						<scale>1</scale>
						<cutoffTickRange>25~30</cutoffTickRange>
						<originOffset>0.4</originOffset>
					</li>
					<li>
						<fleck>Fleck_CERocketSmokeTrail</fleck>
						<emissionsPerTick>2</emissionsPerTick>
						<rotation>0~360</rotation>
						<flecksPerEmission>1</flecksPerEmission>
					</li>
					<li>
						<fleck>Fleck_CERocketSmoke</fleck>
						<emissionsPerTick>2</emissionsPerTick>
						<rotation>0~360</rotation>
						<flecksPerEmission>2</flecksPerEmission>
						<cutoffTickRange>25~60</cutoffTickRange>
					</li>
				</FleckDatas>
			</li>
		</comps>
	</ThingDef>

  	<ThingDef ParentName="BaseVGERocket">
		<thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
        <defName>VGE_Bullet_JavelinPod_CE</defName>
        <label>Gravship javelin rocket</label>
        <graphicData>
            <texPath>Things/Projectiles/Rocket_Javelin</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(2,2)</drawSize>
        </graphicData>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>Bomb</damageDef>
			<damageAmountBase>147</damageAmountBase>
            <explosionRadius>2.9</explosionRadius>
        </projectile>
		<comps>
			<li Class="CombatExtended.CompProperties_Fragments">
				<fragments>
					<Fragment_Small>23</Fragment_Small>
				</fragments>
			</li>
		</comps>
    </ThingDef>

	<!-- === Recipes === -->

	<!-- Thought on VGE :
	
	To stay true to the design philosophy of VGE, each turret has its own distinctive refueling method:
	 - The Gauss gun uses ammo boxes.
	 - The Anticrafter relies on power.
	 - The Rocket Turret consumes gravship fuel through a pipeline connection.
	With that in mind, I decided to introduce a special empty rocket shell that cannot explode on its own
	and is instead loaded and filled directly within the rocket turret building.
	
	-->

	<RecipeDef ParentName="LauncherAmmoRecipeBase">
		<defName>MakeAmmo_Bullet_JavelinPod_CE</defName>
		<label>make empty gravship (HE) javelin rockets x10</label>
		<description>Craft 50 empty gravship (HE) javelin rockets.</description>
		<jobString>Making empty gravship (HE) javelin rockets.</jobString>
		<workAmount>22000</workAmount>
		<ingredients>
			<!-- Recipe is based on MakeAmmo_50mmRocket_HE craft, multiplied by 5, but I removed FSX need -->
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>230</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>20</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Steel</li>
				<li>ComponentIndustrial</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<Ammo_Bullet_JavelinPod_CE>50</Ammo_Bullet_JavelinPod_CE>
		</products>
	</RecipeDef>

	<!-- ====== AnticraftCaster ====== -->

	<!-- === Projectile === -->

	<ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" ParentName="BaseLaserBullet">
		<defName>VGE_Bullet_AnticraftCaster_CE</defName>
        <thingClass>CombatExtended.Compatibility.VGECompat.Projectile_ArtilleryBeamCE</thingClass>
		<label>Anticraft caster beam</label>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>VGE_AnticraftBeamBypassShields</damageDef>
            <damageAmountBase>12</damageAmountBase> <!-- Apply same damage than our Bullet_Laser_BeamRepeater (as it's comparable with VGE bullet) -->
            <flyOverhead>true</flyOverhead>
            <beamMoteDef>VGE_Mote_BeamRepeaterLaser</beamMoteDef>
            <beamStartOffset>1.25</beamStartOffset>
            <armorPenetrationBase>0.5</armorPenetrationBase>
			<shellingProps>
				<tilesPerTick>99999</tilesPerTick>
				<range>36</range> <!-- based on VanillaGravshipExpanded.CompProperties_WorldArtillery.worldMapAttackRange -->
				<damage>0.05</damage>
			</shellingProps>
		</projectile>
		<modExtensions>
			<li Class="ProjectileImpactFX.EffectProjectileExtension">
				<AutoAssign>true</AutoAssign>
				<CreateTerrainEffects>false</CreateTerrainEffects>
				<explosionFleckDef>Fleck_HeatGlow_API</explosionFleckDef>
				<explosionFleckSize>1</explosionFleckSize>
				<ImpactGlowFleckDef>ExplosionFlash</ImpactGlowFleckDef>
				<ImpactGlowFleckSize>2.5</ImpactGlowFleckSize>
			</li>
		</modExtensions>
	</ThingDef>

</Defs>