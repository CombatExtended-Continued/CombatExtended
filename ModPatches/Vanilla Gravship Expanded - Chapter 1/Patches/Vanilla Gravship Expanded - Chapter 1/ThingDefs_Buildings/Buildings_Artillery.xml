	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/ThingDef[defName="VGE_GaussGun"]</xpath>
		<value>
			<li Class="CombatExtended.NonSnapTurretExtension">
				<speed>0.45</speed>
			</li>
		</value>
	</Operation>

