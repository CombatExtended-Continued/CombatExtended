<Patch>

	<!-- Patch Weapons -->
    <Operation Class="PatchOperationRemove">
		<xpath>
			Defs/ThingDef[
				defName = "VGE_GaussGun"
			]/comps/li[
				@Class = "CompProperties_Refuelable" or
				@Class = "VanillaGravshipExpanded.CompProperties_WorldArtillery" or
				@Class = "VanillaGravshipExpanded.CompProperties_BoxRefuel"
			]
		</xpath>
	</Operation>

	<!-- <Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[
			defName = "VGE_Gun_GaussGun"
			]/verbs</xpath>
	</Operation> -->

	<!-- Replace vanilla thingClass -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[
			defName = "VGE_GaussGun"
			]/thingClass </xpath>
		<value>
			<thingClass>CombatExtended.Compatibility.VGECompat.Building_GravshipTurretCE</thingClass>
		</value>
	</Operation>

