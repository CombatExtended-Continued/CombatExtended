<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VGE_Apparel_OxygenPack"]/statBases</xpath>
		<value>
			<Bulk>8</Bulk>
			<WornBulk>1.2</WornBulk>
		</value>
	</Operation>
	
	<!-- Weight is based on 8 pound M-22 (JD) gas tank. 3.7 kilos for empty tank, 890 grams the oxygen inside -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="VGE_Apparel_OxygenPack"]/statBases/Mass</xpath>
		<value>
			<Mass>4.6</Mass>
		</value>
	</Operation>
	
	<!-- This content is only available with Royalty, so we have to do a FindMod patch here -->
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Royalty</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				
				<!-- ========== Prestige Vacsuit ========== -->
				
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VGE_Apparel_Vacsuit_Prestige"]/statBases</xpath>
					<value>
						<Bulk>80</Bulk>
						<WornBulk>12</WornBulk>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VGE_Apparel_Vacsuit_Prestige"]/statBases/ArmorRating_Sharp</xpath>
					<value>
						<ArmorRating_Sharp>3.5</ArmorRating_Sharp>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VGE_Apparel_Vacsuit_Prestige"]/statBases/ArmorRating_Blunt</xpath>
					<value>
						<ArmorRating_Blunt>7</ArmorRating_Blunt>
					</value>
				</li>
				
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VGE_Apparel_Vacsuit_Prestige"]/apparel/bodyPartGroups</xpath>
					<value>
						<li>Hands</li>
						<li>Feet</li>
					</value>
				</li>
				
				<!-- ========== Prestige Vacsuit Helmet ========== -->
				
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VGE_Apparel_VacsuitHelmet_Prestige"]/statBases</xpath>
					<value>
						<Bulk>4</Bulk>
						<WornBulk>1</WornBulk>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VGE_Apparel_VacsuitHelmet_Prestige"]/statBases/ArmorRating_Sharp</xpath>
					<value>
						<ArmorRating_Sharp>3.5</ArmorRating_Sharp>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VGE_Apparel_VacsuitHelmet_Prestige"]/statBases/ArmorRating_Blunt</xpath>
					<value>
						<ArmorRating_Blunt>7</ArmorRating_Blunt>
					</value>
				</li>
				
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VGE_Apparel_VacsuitHelmet_Prestige"]/equippedStatOffsets</xpath>
					<value>
						<SmokeSensitivity>-1</SmokeSensitivity>
					</value>
				</li>
				
				<li Class="PatchOperationAddModExtension">
					<xpath>Defs/ThingDef[defName="VGE_Apparel_VacsuitHelmet_Prestige"]</xpath>
					<value>
						<li Class="CombatExtended.PartialArmorExt">
							<stats>
								<li>
									<ArmorRating_Sharp>0.70</ArmorRating_Sharp>
									<parts>
										<li>Eye</li>
									</parts>
								</li>
								<li>
									<ArmorRating_Blunt>0.70</ArmorRating_Blunt>
									<parts>
										<li>Eye</li>
									</parts>
								</li>
								<li>
									<ArmorRating_Sharp>0.50</ArmorRating_Sharp>
									<parts>
										<li>Nose</li>
										<li>Jaw</li>
									</parts>
								</li>
								<li>
									<ArmorRating_Blunt>0.50</ArmorRating_Blunt>
									<parts>
										<li>Nose</li>
										<li>Jaw</li>
									</parts>
								</li>
							</stats>
						</li>
					</value>
				</li>
				
			</operations>
		</match>
	</Operation>
</Patch>