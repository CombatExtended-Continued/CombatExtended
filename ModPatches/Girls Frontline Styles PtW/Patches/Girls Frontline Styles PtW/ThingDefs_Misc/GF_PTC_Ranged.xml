    <!-- GF Type 95-1/QBZ-95-1 -->
    <Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
        <defName>RFGun_Type95R</defName>
        <statBases>
            <WorkToMake>46000</WorkToMake> <!-- Base + 15% -->
            <Bulk>6.10</Bulk>
            <Mass>3.25</Mass>
            <SightsEfficiency>1.60</SightsEfficiency>
            <ShotSpread>0.07</ShotSpread>
            <SwayFactor>1.04</SwayFactor>
            <RangedWeapon_Cooldown>0.36</RangedWeapon_Cooldown>
        </statBases>
        <costList>
            <chemfuel>15</chemfuel>
            <ComponentIndustrial>12</ComponentIndustrial>
            <Steel>95</Steel>
        </costList>
        <Properties>
            <recoilAmount>1.54</recoilAmount>
            <verbClass>CombatExtended.Verb_ShootCE</verbClass>
            <hasStandardCommand>true</hasStandardCommand>
            <defaultProjectile>Bullet_58x42mmDBP10_FMJ</defaultProjectile>
            <warmupTime>0.9</warmupTime>
            <range>52</range>
            <burstShotCount>6</burstShotCount>
            <ticksBetweenBurstShots>6</ticksBetweenBurstShots>
            <soundCast>Shot_AssaultRifle</soundCast>
            <soundCastTail>GunTail_Medium</soundCastTail>
            <muzzleFlashScale>9</muzzleFlashScale>
        </Properties>
        <AmmoUser>
            <magazineSize>30</magazineSize>
            <reloadTime>3.8</reloadTime>
            <ammoSet>AmmoSet_58x42mmDBP10</ammoSet>
        </AmmoUser>
        <FireModes>
            <aiUseBurstMode>TRUE</aiUseBurstMode>
            <aiAimMode>AimedShot</aiAimMode>
            <aimedBurstShotCount>3</aimedBurstShotCount>
        </FireModes>
        <weaponTags>
            <li>CE_AI_AR</li>
            <li>IndustrialGunAdvanced</li>
        </weaponTags>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="RFGun_Type95R"]/label</xpath>
