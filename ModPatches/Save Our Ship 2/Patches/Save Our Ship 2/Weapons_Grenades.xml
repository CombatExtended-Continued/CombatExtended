<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ========== Molotov cocktail ========== -->

	<!-- Projectile -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Proj_GrenadeMechanite"]/graphicData/texPath</xpath>
		<value>
			<texPath>Things/Projectile/Grenades/Molotov</texPath>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[@Name="BaseMechaniteProjectile"]/projectile</xpath>
		<value>
			<projectile Class="CombatExtended.ProjectilePropertiesCE">
				<explosionRadius>1.1</explosionRadius>
				<damageDef>BombMechanite</damageDef>
				<damageAmountBase>10</damageAmountBase>
				<speed>12</speed>
				<ai_IsIncendiary>true</ai_IsIncendiary>
			</projectile>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Proj_GrenadeMechanite"]</xpath>
		<value>
			<thingClass>CombatExtended.Projectile_FireTrail</thingClass>
		</value>
	</Operation>

	<!-- Grenade -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Weapon_GrenadeMechanite"]/label</xpath>
		<value>
			<label>mechanite cocktail</label>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Weapon_GrenadeMechanite"]/graphicData</xpath>
		<value>
			<graphicData>
				<texPath>Things/Ammo/HandGrenades/Molotov</texPath>
				<graphicClass>Graphic_StackCount</graphicClass>
				<onGroundRandomRotateAngle>0</onGroundRandomRotateAngle>
			</graphicData>
		</value>
	</Operation>

	<Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[defName="Weapon_GrenadeMechanite"]/verbs</xpath>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Weapon_GrenadeMechanite"]</xpath>
		<value>
			<thingClass>CombatExtended.AmmoThing</thingClass>
			<stackLimit>50</stackLimit>
			<resourceReadoutPriority>First</resourceReadoutPriority>
		</value>
	</Operation>

	<Operation Class="PatchOperationAttributeSet">
		<xpath>Defs/ThingDef[defName="Weapon_GrenadeMechanite"]</xpath>
		<attribute>Class</attribute>
		<value>CombatExtended.AmmoDef</value>
	</Operation>

	<Operation Class="PatchOperationConditional">
		<xpath>Defs/ThingDef[defName="Weapon_GrenadeMechanite"]/comps</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/ThingDef[defName="Weapon_GrenadeMechanite"]</xpath>
			<value>
				<comps />
			</value>
		</nomatch>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Weapon_GrenadeMechanite"]/comps/li[@Class="CompProperties_Explosive"]</xpath>
		<value>
			<li Class="CombatExtended.CompProperties_ExplosiveCE">
				<explosiveRadius>2.66</explosiveRadius>
				<explosiveDamageType>BombMechanite</explosiveDamageType>
				<preExplosionSpawnThingDef>Filth_Fuel</preExplosionSpawnThingDef>
				<preExplosionSpawnChance>1</preExplosionSpawnChance>
			</li>
		</value>
	</Operation>

	<Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
		<defName>Weapon_GrenadeMechanite</defName>
		<statBases>
			<Mass>0.6</Mass>
			<Bulk>2.55</Bulk>
			<RangedWeapon_Cooldown>1</RangedWeapon_Cooldown>
			<SightsEfficiency>1.0</SightsEfficiency>
		</statBases>
		<Properties>
			<label>throw molotov</label>
			<verbClass>CombatExtended.Verb_ShootCEOneUse</verbClass>
			<hasStandardCommand>true</hasStandardCommand>
			<range>10</range>
			<minRange>4</minRange>
			<warmupTime>0.8</warmupTime>
			<noiseRadius>4</noiseRadius>
			<ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
			<soundCast>ThrowMolotovCocktail</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
			<defaultProjectile>Proj_GrenadeMechanite</defaultProjectile>
			<onlyManualCast>true</onlyManualCast>
			<ignorePartialLoSBlocker>true</ignorePartialLoSBlocker>
		</Properties>
		<weaponTags>
			<li>CE_AI_Grenade</li>
			<li>CE_OneHandedWeapon</li>
		</weaponTags>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Weapon_GrenadeMechanite"]</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>handle</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>12</power>
					<cooldownTime>1</cooldownTime>
					<armorPenetrationBlunt>0.55</armorPenetrationBlunt>
					<linkedBodyPartsGroup>Handle</linkedBodyPartsGroup>
				</li>
			</tools>
		</value>
	</Operation>

	<!--Vanilla Textures Expanded - Save Our Ship 2-->

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Textures Expanded - Save Our Ship 2</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="Proj_GrenadeMechanite"]/graphicData/texPath</xpath>
					<value>
						<texPath>Things/Item/GrenadeMechanite_Thrown</texPath>
					</value>
				</li>

				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="Weapon_GrenadeMechanite"]/graphicData</xpath>
					<value>
						<graphicData>
							<texPath>Things/Ammo/HandGrenades/GrenadeMechanite</texPath>
							<graphicClass>Graphic_StackCount</graphicClass>
							<onGroundRandomRotateAngle>0</onGroundRandomRotateAngle>
						</graphicData>
					</value>
				</li>

				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="Weapon_GrenadeMechanite"]/label</xpath>
					<value>
						<label>mechanite grenade</label>
					</value>
				</li>
			</operations>
		</match>
	</Operation>

</Patch>