<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Industrial Hunter -->
	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/PawnKindDef[defName="VEE_Hunter"]</xpath>
		<value>
			<li Class="CombatExtended.LoadoutPropertiesExtension">
				<primaryMagazineCount>
					<min>2</min>
					<max>4</max>
				</primaryMagazineCount>
				<sidearms>
					<li>
						<generateChance>0.25</generateChance>
						<sidearmMoney>
							<min>20</min>
							<max>120</max>
						</sidearmMoney>
						<weaponTags>
							<li>CE_Sidearm_Melee</li>
						</weaponTags>
					</li>
				</sidearms>
			</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/PawnKindDef[defName="VEE_Hunter"]</xpath>
		<value>
			<apparelRequired>
				<li>CE_Apparel_Backpack</li>
			</apparelRequired>
		</value>
	</Operation>

	<!-- Tribal Hunter -->
	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/PawnKindDef[defName="VEE_TribalHunter"]</xpath>
		<value>
			<li Class="CombatExtended.LoadoutPropertiesExtension">
				<primaryMagazineCount>
					<min>5</min>
					<max>7</max>
				</primaryMagazineCount>
				<forcedAmmoCategory>StoneArrow</forcedAmmoCategory> <!-- Prevent the AI lighting the colony map on fire with flame arrows. -->
				<sidearms>
					<li>
						<generateChance>0.4</generateChance>					
						<sidearmMoney>
							<min>80</min>
							<max>160</max>
						</sidearmMoney>
						<weaponTags>
							<li>CE_Sidearm_Tribal</li>
						</weaponTags>
					</li>
				</sidearms>
			</li>
		</value>
	</Operation>

</Patch>