<?xml version="1.0" encoding="utf-8" ?>
<Patch>

	<!-- Faulty Recon - Add Ammo -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ScenarioDef[defName="HOI_FaultyRecon"]/scenario/parts</xpath>
		<value>
			<li Class="ScenPart_StartingThing_Defined">
				<def>StartingThing_Defined</def>
				<thingDef>Ammo_LasgunPowerPack</thingDef>
				<count>960</count>
			</li>
			<li Class="ScenPart_StartingThing_Defined">
				<def>StartingThing_Defined</def>
				<thingDef>Ammo_825mmLong_FMJ</thingDef>
				<count>400</count>
			</li>			
		</value>
	</Operation>

	<!-- Alone in the Wild - Add Ammo -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ScenarioDef[defName="HOI_AloneInTheWild"]/scenario/parts</xpath>
		<value>
			<li Class="ScenPart_StartingThing_Defined">
				<def>StartingThing_Defined</def>
				<thingDef>Ammo_LasgunPowerPack</thingDef>
				<count>320</count>
			</li>
		</value>
	</Operation>

</Patch>