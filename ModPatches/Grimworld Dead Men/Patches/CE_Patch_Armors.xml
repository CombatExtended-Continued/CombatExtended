<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<!-- Helmets -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegGuardHelmet" or defName="GW_HOI_DM_KriegEngineerHelmet"]/statBases</xpath>
		<value>
			<Bulk>4</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegGuardHelmet" or defName="GW_HOI_DM_KriegEngineerHelmet"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>6.5</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegGuardHelmet" or defName="GW_HOI_DM_KriegEngineerHelmet"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>9.75</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegGrenadierHelmet" or defName="GW_HOI_DM_KriegOfficerHelmet" or defName="GW_HOI_DM_KriegCommissarHelmet"]/statBases</xpath>
		<value>
			<Bulk>5</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegGrenadierHelmet" or defName="GW_HOI_DM_KriegOfficerHelmet" or defName="GW_HOI_DM_KriegCommissarHelmet"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>8</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegGrenadierHelmet" or defName="GW_HOI_DM_KriegOfficerHelmet" or defName="GW_HOI_DM_KriegCommissarHelmet"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>12</ArmorRating_Blunt>
		</value>
	</Operation>

	<!-- Webbing -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegBelt" or defName="GW_HOI_DM_KriegEngineerPack"]/apparel/layers/li[.="Belt"]</xpath>
		<value>
			<li>Webbing</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegBelt" or defName="GW_HOI_DM_KriegEngineerPack"]/apparel/bodyPartGroups/li[.="Waist"]</xpath>
		<value>
			<li>Shoulders</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegBelt" or defName="GW_HOI_DM_KriegEngineerPack"]/statBases</xpath>
		<value>
			<Bulk>10</Bulk>
			<WornBulk>5</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegBelt"]/equippedStatOffsets</xpath>
		<value>
			<CarryBulk>20</CarryBulk>
			<ReloadSpeed>0.1</ReloadSpeed>
		</value>
	</Operation>

	<!-- Fatigues -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegUniform" or defName="GW_HOI_DM_KriegOfficerUniform" or defName="GW_HOI_DM_CommissarUniform"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>4</StuffEffectMultiplierArmor>
			<Bulk>4</Bulk>
			<WornBulk>2</WornBulk>
		</value>
	</Operation>

	<!-- Krieg Armor -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegEngineerMiddle" or defName="GW_HOI_DM_KriegGrenadierArmor" or defName="GW_HOI_DM_KriegOfficerArmor"]/statBases</xpath>
		<value>
			<Bulk>10</Bulk>
			<WornBulk>5</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegEngineerMiddle" or defName="GW_HOI_DM_KriegGrenadierArmor" or defName="GW_HOI_DM_KriegOfficerArmor"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>12</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegEngineerMiddle" or defName="GW_HOI_DM_KriegGrenadierArmor" or defName="GW_HOI_DM_KriegOfficerArmor"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>18</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="GW_HOI_DM_KriegCommissarOuter" or defName="GW_HOI_DM_KriegOfficerOuter"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>5</StuffEffectMultiplierArmor>
		</value>
	</Operation>

</Patch>
