<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- == Military coat == -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VQED_Apparel_MilitaryCoat"]/statBases</xpath>
		<value>
			<Bulk>5</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="VQED_Apparel_MilitaryCoat"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>0.75</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="VQED_Apparel_MilitaryCoat"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>0.25</ArmorRating_Blunt>
		</value>
	</Operation>

	<!-- == General's Insignia == -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VQED_Apparel_GeneralsInsignia"]/statBases</xpath>
		<value>
			<Bulk>0.1</Bulk>
			<ArmorRating_Sharp>0.01</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.01</ArmorRating_Blunt>
		</value>
	</Operation>

	<!-- == General's Cap == -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VQED_Apparel_GeneralsCap"]/statBases</xpath>
		<value>
			<Bulk>1</Bulk>
		</value>
	</Operation>

</Patch>