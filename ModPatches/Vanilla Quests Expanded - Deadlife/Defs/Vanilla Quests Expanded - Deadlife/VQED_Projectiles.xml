<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- VQED weapons don't consume ammo, instead evenutally falling apart. -->
    <ThingDef ParentName="Base9x19mmParaBullet">
        <defName>Bullet_9x19mmPara_VQEDL</defName>
        <label>9mm Para bullet (HP)</label>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageAmountBase>13</damageAmountBase>
            <armorPenetrationSharp>2</armorPenetrationSharp>
            <armorPenetrationBlunt>9.66</armorPenetrationBlunt>
            <weaponDeteriorationChance>1</weaponDeteriorationChance>
            <weaponDeteriorationHP>1~2</weaponDeteriorationHP>
        </projectile>
    </ThingDef>

    <ThingDef ParentName="Base12GaugeBullet">
        <defName>Bullet_12Gauge_VQEDL</defName>
        <label>buckshot pellets</label>
        <graphicData>
            <texPath>Things/Projectile/Shotgun_Pellet</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageAmountBase>8</damageAmountBase>
            <pelletCount>9</pelletCount>
            <armorPenetrationSharp>4</armorPenetrationSharp>
            <armorPenetrationBlunt>4.52</armorPenetrationBlunt>
            <spreadMult>8.9</spreadMult>
            <weaponDeteriorationChance>0.95</weaponDeteriorationChance>
            <weaponDeteriorationHP>3~4</weaponDeteriorationHP>
        </projectile>
    </ThingDef>

    <ThingDef ParentName="Base792x57mmMauserBullet">
        <defName>Bullet_792x57mmMauser_VQEDL</defName>
        <label>7.92mm Mauser bullet (HP)</label>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageAmountBase>27</damageAmountBase>
            <armorPenetrationSharp>4</armorPenetrationSharp>
            <armorPenetrationBlunt>78.68</armorPenetrationBlunt>
            <weaponDeteriorationChance>1</weaponDeteriorationChance>
            <weaponDeteriorationHP>0~1.1</weaponDeteriorationHP>
        </projectile>
    </ThingDef>

</Defs>