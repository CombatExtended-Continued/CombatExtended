		<value>
			<ArmorRating_Sharp>0.2</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.3</ArmorRating_Blunt>
		</value>
	</Operation>

	<!--Nightcap Chen Hat-->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_TH_ZUNhatCHEN"]/statBases</xpath>
		<value>
			<ArmorRating_Sharp>0.2</ArmorRating_Sharp>
