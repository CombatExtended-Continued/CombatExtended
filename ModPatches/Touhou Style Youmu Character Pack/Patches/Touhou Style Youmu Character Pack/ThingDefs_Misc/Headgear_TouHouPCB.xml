<?xml version="1.0" encoding="UTF-8"?>
<Patch>

	<!-- ============================ Hat & Headset ============================ -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
			defName="Apparel_TH_ZUNhatBBA" or
			defName="Apparel_TH_ZUNhatYYZ" or
			defName="Apparel_TH_ZUNhatRAN" or
			defName="Apparel_TH_ZUNhatCHEN"
			]/statBases</xpath>
		<value>
			<Bulk>3</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<!--Nightcap Yukari Hat-->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_TH_ZUNhatBBA"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>5.6</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_TH_ZUNhatBBA"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>6.8</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_TH_ZUNhatBBA"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
		<value>
			<ShootingAccuracyPawn>0.04</ShootingAccuracyPawn>
			<AimingAccuracy>0.02</AimingAccuracy>
			<Suppressability>-0.1</Suppressability>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_TH_ZUNhatBBA"]/equippedStatOffsets/Flammability</xpath>
		<value>
			<Flammability>-1</Flammability>
		</value>
	</Operation>

	<!--Nightcap Yuyuko Hat-->
