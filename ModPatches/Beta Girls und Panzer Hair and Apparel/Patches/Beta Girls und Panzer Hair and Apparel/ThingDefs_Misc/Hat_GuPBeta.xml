<?xml version="1.0" encoding="UTF-8"?>
<Patch>
    <!-- ============================ Hat & Headset ============================ -->
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[
            defName="StarsUniversityUniform_Hat" or
            defName="BCFreedomUniform_Hat" or
            defName="KuromorimineUniform_Hat"
            ]/statBases</xpath>
        <value>
            <Bulk>3</Bulk>
            <WornBulk>1</WornBulk>
            <Flammability>0.0</Flammability>
        </value>
    </Operation>

    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[
            defName="StarsUniversityUniform_Hat" or
            defName="BCFreedomUniform_Hat" or
            defName="KuromorimineUniform_Hat"
            ]/equippedStatOffsets</xpath>
        <value>
            <ToxicEnvironmentResistance MayRequire="Ludeon.RimWorld.Biotech">1.0</ToxicEnvironmentResistance>
            <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">1.0</VacuumResistance>
        </value>
    </Operation>

    <!--Stars University Hat-->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="StarsUniversityUniform_Hat"]/statBases/ArmorRating_Sharp</xpath>
        <value>
            <ArmorRating_Sharp>6.6</ArmorRating_Sharp>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="StarsUniversityUniform_Hat"]/statBases/ArmorRating_Blunt</xpath>
        <value>
            <ArmorRating_Blunt>3.3</ArmorRating_Blunt>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="StarsUniversityUniform_Hat"]/statBases/ArmorRating_Heat</xpath>
        <value>
            <ArmorRating_Heat>0.5</ArmorRating_Heat>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="StarsUniversityUniform_Hat"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
        <value>
            <ShootingAccuracyPawn>0.05</ShootingAccuracyPawn>
            <AimingAccuracy>0.025</AimingAccuracy>
        </value>
    </Operation>

    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="StarsUniversityUniform_Hat"]/equippedStatOffsets</xpath>
        <value>
            <Flammability>-1.0</Flammability>
            <Suppressability>-0.1</Suppressability>
        </value>
    </Operation>

    <!--BC Freedom Hat-->
