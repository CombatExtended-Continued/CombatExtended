        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="BCFreedomUniform_Hat"]/statBases/ArmorRating_Heat</xpath>
        <value>
            <ArmorRating_Heat>0.5</ArmorRating_Heat>
