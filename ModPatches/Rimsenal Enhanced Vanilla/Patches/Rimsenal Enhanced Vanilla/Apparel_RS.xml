 <ThingDef ParentName="ArmorMachineableBase">
    <defName>Apparel_ProtectiveGear</defName>
    <label>heavy flak armor</label>
    <description>A heavy, non-powered suit of armor that provides full-body coverage, though it lacks the defensive capabilities of powered armor.</description>
    <techLevel>Industrial</techLevel>
    <recipeMaker>
      <researchPrerequisite>FlakArmor</researchPrerequisite>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <skillRequirements>
        <Crafting>6</Crafting>
      </skillRequirements>
    </recipeMaker>
    <graphicData>
      <texPath>Things/Apparel/ProtectiveGear</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <WorkToMake>18600</WorkToMake>
      <MaxHitPoints>300</MaxHitPoints>
      <Mass>15</Mass>
      <Flammability>0.6</Flammability>
      <ArmorRating_Blunt>0.5</ArmorRating_Blunt>
      <ArmorRating_Sharp>1.05</ArmorRating_Sharp>
      <ArmorRating_Heat>0.35</ArmorRating_Heat>
      <Insulation_Cold>25</Insulation_Cold>
      <EquipDelay>15</EquipDelay>
    </statBases>
    <thingCategories>
      <li>ApparelArmor</li>
    </thingCategories>
    <equippedStatOffsets>
      <MoveSpeed>-0.7</MoveSpeed>
    </equippedStatOffsets>
    <costList>
      <Steel>105</Steel>
      <Plasteel>45</Plasteel>
      <ComponentIndustrial>4</ComponentIndustrial>
    </costList>
      <generateCommonality>0.1</generateCommonality>
    <apparel>
      <bodyPartGroups>
	    <li>Neck</li>
        <li>Shoulders</li>
        <li>Torso</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Apparel/ProtectiveGear</wornGraphicPath>
      <layers>
        <li>Middle</li>
        <li>Shell</li>
      </layers>
      <tags>
        <li>IndustrialMilitaryAdvanced</li>
      </tags>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags> </apparel>
  </ThingDef>

  <ThingDef ParentName="ArmorHelmetMakeableBase">
    <defName>Apparel_ProtectiveHelmet</defName>
    <label>heavy flak helmet</label>
    <description>A heavy combat helmet that provides full head protection.</description>
    <graphicData> <texPath>Things/Apparel/ProtectiveHelmet</texPath>
    <graphicClass>Graphic_Single</graphicClass> </graphicData>
    <statBases>
      <Mass>2.62</Mass>
      <WorkToMake>10000</WorkToMake>
      <MaxHitPoints>320</MaxHitPoints>
      <ArmorRating_Blunt>0.35</ArmorRating_Blunt>
      <ArmorRating_Sharp>1.05</ArmorRating_Sharp>
      <ArmorRating_Heat>0.36</ArmorRating_Heat>
      <Insulation_Cold>5</Insulation_Cold>
      <Insulation_Heat>5</Insulation_Heat>
      <EquipDelay>8</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <MoveSpeed>-0.2</MoveSpeed>
    </equippedStatOffsets>
    <recipeMaker>
      <researchPrerequisite>FlakArmor</researchPrerequisite>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
    </recipeMaker>
    <costList>
      <ComponentIndustrial>2</ComponentIndustrial>
      <Plasteel>25</Plasteel>
      <Steel>35</Steel>
    </costList>
      <generateCommonality>0.8</generateCommonality>
    <apparel>
			<bodyPartGroups>
				<li>FullHead</li>
			</bodyPartGroups>
      <wornGraphicPath>Things/Apparel/ProtectiveHelmet</wornGraphicPath>
      <layers>
        <li>Overhead</li>
      </layers>
      <tags>
        <li>IndustrialMilitaryAdvanced</li>
      </tags>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
    </apparel>
  </ThingDef>


</Defs>