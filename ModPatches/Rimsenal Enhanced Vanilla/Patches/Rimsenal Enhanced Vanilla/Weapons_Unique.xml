<?xml version="1.0" encoding="utf-8"?>

<Defs>

  <ThingDef ParentName="Gun_RSCarbine" MayRequire="ludeon.rimworld.odyssey">
    <defName>Gun_RSCarbine_Unique</defName>
    <label>unique carbine</label>
    <description>A carbine with customized parts.</description>
    <graphicData>
      <texPath>Things/Item/Equipment/WeaponRanged/UniqueWeapons/RSCarbine</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <shaderType>CutoutComplex</shaderType>
    </graphicData>
    <!-- Can't inherit comps because we need to override CompEquippable with CompEquippableAbility -->
    <!-- If changes are made to the comps of BaseHumanMakeableGun or parents then they will need to be replicated here -->
    <comps Inherit="False">
      <li Class="CompProperties_EquippableAbilityReloadable" /> <!-- Props are populated by traits -->
      <li Class="CompProperties_Forbiddable"/>
      <li Class="CompProperties_Styleable"/>
      <li Class="CompProperties_Biocodable"/>
      <li>
        <compClass>CompQuality</compClass>
      </li>
      <li Class="CompProperties_Art">
        <nameMaker>NamerArtWeaponGun</nameMaker>
        <descriptionMaker>ArtDescription_WeaponGun</descriptionMaker>
        <minQualityForArtistic>Excellent</minQualityForArtistic>
      </li>
      <li Class="CompProperties_UniqueWeapon">
        <weaponCategories>
          <li>Ranged</li>
          <li>BulletFiring</li>
          <li>Gun</li>
          <li>Sighted</li>
          <li>Rifle</li>
          <li>BurstFire</li>
          <li>LowStoppingPower</li>
          <li>Attachable</li>
        </weaponCategories>
        <namerLabels>
          <li>battle carbine</li>
          <li>carbine</li>
          <li>storm carbine</li>
          <li>war carbine</li>
          <li>wargun</li>
          <li>stormgun</li>
        </namerLabels>
      </li>
    </comps>
    <generateAllowChance>0</generateAllowChance>
    <possessionCount>0</possessionCount>
    <tradeability>Sellable</tradeability>
    <thingSetMakerTags Inherit="False" >
      <li>RewardStandardLowFreq</li>
      <li>UniqueWeapon</li>
    </thingSetMakerTags>
    <recipeMaker Inherit="False" IsNull="True" />
    <thingCategories Inherit="False">
      <li>WeaponsUnique</li>
    </thingCategories>
    <descriptionHyperlinks>
      <ThingDef>Gun_RSCarbine</ThingDef>
    </descriptionHyperlinks>
  </ThingDef>


