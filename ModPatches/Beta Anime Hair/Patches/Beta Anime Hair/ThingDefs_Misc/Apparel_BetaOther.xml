<?xml version="1.0" encoding="UTF-8"?>
<Patch>
	<!-- ============================ Coat ============================ -->
	<!-- Uses Uniforms CarryWeight 2 for Base; 4 for Advanced/Mod3 -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="22Uniform" or defName="33Uniform"]/statBases</xpath>
		<value>
			<Bulk>4</Bulk>
			<WornBulk>2</WornBulk>
		</value>
	</Operation>

	<!-- 22 Uniform Coat -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="22Uniform"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>6</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="22Uniform"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>9</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="22Uniform"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
		<value>
			<ShootingAccuracyPawn>0.12</ShootingAccuracyPawn>
			<AimingAccuracy>0.06</AimingAccuracy>
			<Suppressability>-0.1</Suppressability>
		</value>
	</Operation>

	<!-- 33 Uniform Coat -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="33Uniform"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>4</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="33Uniform"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>6</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="33Uniform"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
		<value>
			<ShootingAccuracyPawn>0.12</ShootingAccuracyPawn>
			<AimingAccuracy>0.06</AimingAccuracy>
			<Suppressability>-0.1</Suppressability>
		</value>
	</Operation>

</Patch>