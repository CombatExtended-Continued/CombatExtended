			<MeleeDodgeChance>0.24</MeleeDodgeChance>
			<MeleeCritChance>0.30</MeleeCritChance>
			<MeleeParryChance>0.06</MeleeParryChance>
			<ArmorRating_Sharp>14</ArmorRating_Sharp>
			<ArmorRating_Blunt>21</ArmorRating_Blunt>
		</value>
	</Operation>

