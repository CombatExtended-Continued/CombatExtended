<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<!-- This content is only available with Biotech, so we have to do a FindMod patch here -->
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Biotech</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<!-- Graser Cannon Complex -->
				<!-- Stats here are mostly based on the Biotech beam graser, with some patches reused from the Rimsenal Security patch -->
				
				<li Class="PatchOperationRemove">
					<xpath>Defs/ThingDef[defName="VFES_Complex_GraserCannon"]/comps/li[@Class="CompProperties_Refuelable"]</xpath>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VFES_Complex_GraserCannon"]/fillPercent</xpath>
					<value>
						<fillPercent>0.85</fillPercent>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VFES_ComplexGraserCannon_Top"]/statBases/RangedWeapon_Cooldown</xpath>
					<value>
						<RangedWeapon_Cooldown>0.56</RangedWeapon_Cooldown>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VFES_ComplexGraserCannon_Top"]/statBases/AccuracyTouch</xpath>
					<value>
						<AccuracyTouch>1</AccuracyTouch>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VFES_ComplexGraserCannon_Top"]/statBases/AccuracyShort</xpath>
					<value>
						<AccuracyShort>1</AccuracyShort>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VFES_ComplexGraserCannon_Top"]/statBases/AccuracyMedium</xpath>
					<value>
						<AccuracyMedium>1</AccuracyMedium>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VFES_ComplexGraserCannon_Top"]/statBases/AccuracyLong</xpath>
					<value>
						<AccuracyLong>1</AccuracyLong>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VFES_ComplexGraserCannon_Top"]/verbs/li/warmupTime</xpath>
					<value>
						<warmupTime>1</warmupTime>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VFES_ComplexGraserCannon_Top"]/verbs/li/range</xpath>
					<value>
						<range>55</range>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VFES_ComplexGraserCannon_Top"]/verbs/li/burstShotCount</xpath>
					<value>
						<burstShotCount>125</burstShotCount>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VFES_ComplexGraserCannon_Top"]/verbs/li/beamMaxDeviation</xpath>
					<value>
						<beamMaxDeviation>0.5</beamMaxDeviation>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VFES_ComplexGraserCannon_Top"]/verbs/li/ticksBetweenBurstShots</xpath>
					<value>
						<ticksBetweenBurstShots>1</ticksBetweenBurstShots>
					</value>
				</li>
				
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VFES_ComplexGraserCannon_Top"]/verbs/li/beamWidth</xpath>
					<value>
						<beamWidth>12.5</beamWidth>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
</Patch>