	<Operation Class="PatchOperationReplace">
		<xpath>Defs/AbilityDef[defName="CAT_PunishmentBlast"]/comps/li[@Class="CompProperties_AbilityLaunchProjectile"]/projectileDef</xpath>
		<value>
			<projectileDef>CAT_PunishmentBlast_CE</projectileDef>
		</value>
