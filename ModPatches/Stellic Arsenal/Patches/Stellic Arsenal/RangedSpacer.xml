		</FireModes>
		<weaponTags>
			<li>CE_AI_Rifle</li>
		</weaponTags>
	</Operation>

	<Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[defName="CAT_StellicCarbine"]/comps/li[@Class="MVCF.Comps.CompProperties_VerbProps"]</xpath>
	</Operation>

