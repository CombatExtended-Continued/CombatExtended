<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ==================== Advanced Militor Add Covered By Natural Armor ==================== -->
	
	<!-- Core Part (Thorax) -->
	<Operation Class="PatchOperationSequence">
		<operations>
			<li Class="PatchOperationConditional">
				<xpath>Defs/BodyDef[defName="Mech_AdvancedMilitor"]/corePart/groups</xpath>
				<nomatch Class="PatchOperationAdd">
					<xpath>Defs/BodyDef[defName="Mech_AdvancedMilitor"]/corePart</xpath>
					<value>
						<groups />
					</value>
				</nomatch>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/BodyDef[defName="Mech_AdvancedMilitor"]/corePart/groups</xpath>
				<value>
					<li>CoveredByNaturalArmor</li>
				</value>
			</li>
		</operations>
	</Operation>

