<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Royalty</li>
		</mods>

		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Royalty">
					<xpath>Defs/ThingDef[defName="DR_SoulMace"]/tools</xpath>
					<value>
						<tools>
							<li Class="CombatExtended.ToolCE">
								<label>handle</label>
								<capacities>
									<li>Poke</li>
								</capacities>
								<power>5</power>
								<cooldownTime>1.37</cooldownTime>
								<armorPenetrationBlunt>0.87</armorPenetrationBlunt>
								<linkedBodyPartsGroup>Handle</linkedBodyPartsGroup>
							</li>
							<li Class="CombatExtended.ToolCE">
								<label>head</label>
								<capacities>
									<li>DR_SoulMace</li>
								</capacities>
								<power>58</power>
								<cooldownTime>2.19</cooldownTime>
								<armorPenetrationBlunt>200</armorPenetrationBlunt>
								<linkedBodyPartsGroup>Head</linkedBodyPartsGroup>
							</li>
						</tools>
					</value>
				</li>

				<li Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Royalty">
					<xpath>Defs/ThingDef[defName="DR_SoulMace"]/statBases</xpath>
					<value>
						<Bulk>8</Bulk>
						<MeleeCounterParryBonus>0.70</MeleeCounterParryBonus>
					</value>
				</li>

				<li Class="PatchOperationConditional" MayRequire="Ludeon.RimWorld.Royalty">
					<xpath>Defs/ThingDef[defName="DR_SoulMace"]/equippedStatOffsets</xpath>
					<nomatch Class="PatchOperationAdd">
						<xpath>Defs/ThingDef[defName="DR_SoulMace"]</xpath>
						<value>
							<equippedStatOffsets/>
						</value>
					</nomatch>
				</li>

				<li Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Royalty">
					<xpath>Defs/ThingDef[defName="DR_SoulMace"]/equippedStatOffsets</xpath>
					<value>
						<MeleeCritChance>1.1</MeleeCritChance>
						<MeleeParryChance>0.55</MeleeParryChance>
						<MeleeDodgeChance>0.40</MeleeDodgeChance>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
	
</Patch>