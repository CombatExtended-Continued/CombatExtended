<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!-- ========== Plasma ========== -->
    
	<DamageDef ParentName="Bullet">
    <defName>CE_Plasma</defName>
    <label>plasma shot</label>
    <workerClass>DamageWorker_AddInjury</workerClass>
    <externalViolence>true</externalViolence>
    <deathMessage>{0} has been killed by plasma.</deathMessage>
    <hediff>BurnSecondary</hediff>
    <impactSoundType>Electric</impactSoundType>
    <hasForcefulImpact>true</hasForcefulImpact>
    <makesBlood>false</makesBlood>
	<minDamageToFragment>99999</minDamageToFragment>
	<defaultDamage>1</defaultDamage>
	<defaultArmorPenetration>0</defaultArmorPenetration>
	<modExtensions>
		<li Class="CombatExtended.DamageDefExtensionCE">
			<canCauseWallFragmentation>false</canCauseWallFragmentation>
			<harmOnlyOutsideLayers>true</harmOnlyOutsideLayers>
		</li>
	</modExtensions>
  </DamageDef>
    
    <!-- ========== Photon ========== -->
  <DamageDef ParentName="Bullet">
    <defName>CE_Photon</defName>
    <label>photon scorch</label>
    <deathMessage>{0} has been scorched to death.</deathMessage>
    <hediff>BurnSecondary</hediff>
	<hasForcefulImpact>false</hasForcefulImpact>
	<minDamageToFragment>99999</minDamageToFragment>
	<defaultDamage>1</defaultDamage>
	<defaultArmorPenetration>0</defaultArmorPenetration>
	<buildingDamageFactor>0.1</buildingDamageFactor>
	<plantDamageFactor>2</plantDamageFactor>
    <impactSoundType>Electric</impactSoundType>
    <hasForcefulImpact>true</hasForcefulImpact>
    <makesBlood>false</makesBlood>
	<modExtensions>
		<li Class="CombatExtended.DamageDefExtensionCE">
			<canCauseWallFragmentation>false</canCauseWallFragmentation>
		</li>
	</modExtensions>
  </DamageDef>
    
    <!-- ========== Neutron ========== -->  

  <DamageDef ParentName="Bullet">
    <defName>CE_Neutron</defName>
    <label>neutron particle</label>
    <hasForcefulImpact>false</hasForcefulImpact>
    <makesBlood>false</makesBlood>
    <deathMessage>{0} has been irradiated to death.</deathMessage>
    <hediff>DV_RadBurn_Hediff</hediff>
    <impactSoundType>Electric</impactSoundType>
    <buildingDamageFactorImpassable>0.2</buildingDamageFactorImpassable>
    <plantDamageFactor>3</plantDamageFactor>
	<minDamageToFragment>99999</minDamageToFragment>
	<defaultDamage>1</defaultDamage>
	<defaultArmorPenetration>0</defaultArmorPenetration>
	<hasForcefulImpact>true</hasForcefulImpact>
    <makesBlood>false</makesBlood>
	<modExtensions>
		<li Class="CombatExtended.DamageDefExtensionCE">
			<canCauseWallFragmentation>false</canCauseWallFragmentation>
		</li>
	</modExtensions>
  </DamageDef>
	
</Defs>