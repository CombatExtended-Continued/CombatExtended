<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!-- ========== Neutron ========== -->

	<DamageDef ParentName="Bullet">
		<defName>CE_Neutron</defName>
		<label>neutron particle</label>
		<deathMessage>{0} has been irradiated to death.</deathMessage>
		<hediff>DV_RadBurn_Hediff</hediff>
		<impactSoundType>Electric</impactSoundType>
		<minDamageToFragment>99999</minDamageToFragment>
		<defaultArmorPenetration>0.5</defaultArmorPenetration>
		<modExtensions>
			<li Class="CombatExtended.DamageDefExtensionCE">
				<canCauseWallFragmentation>false</canCauseWallFragmentation>
			</li>
		</modExtensions>
	</DamageDef>

</Defs>