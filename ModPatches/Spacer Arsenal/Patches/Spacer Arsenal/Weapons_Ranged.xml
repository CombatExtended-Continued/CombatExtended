	<!-- Laserpulse Longrifle -->

	<!-- Due to complications with patching (Yet another case of adding Defs with patches) I have
	been forced to do this-->

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Det's Xenotypes - Venators</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>

				<li Class="PatchOperationAttributeSet">
					<xpath>Defs/ThingDef[defName="DV_Gun_LaserpulseLongrifle"]</xpath>
					<attribute>ParentName</attribute>
					<value>BaseHumanMakeableGun</value>
				</li>

				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="DV_Gun_LaserpulseLongrifle"]/tools
					</xpath>
					<value>
						<tools>
							<li Class="CombatExtended.ToolCE">
								<label>stock</label>
								<capacities>
									<li>Blunt</li>
								</capacities>
								<power>8</power>
								<cooldownTime>1.55</cooldownTime>
								<chanceFactor>1.5</chanceFactor>
								<armorPenetrationBlunt>2.755</armorPenetrationBlunt>
								<linkedBodyPartsGroup>Stock</linkedBodyPartsGroup>
							</li>
							<li Class="CombatExtended.ToolCE">
								<label>barrel</label>
								<capacities>
									<li>Blunt</li>
								</capacities>
								<power>5</power>
								<cooldownTime>2.02</cooldownTime>
								<armorPenetrationBlunt>1.630</armorPenetrationBlunt>
								<linkedBodyPartsGroup>Barrel</linkedBodyPartsGroup>
							</li>
							<li Class="CombatExtended.ToolCE">
								<label>muzzle</label>
								<capacities>
									<li>Poke</li>
								</capacities>
								<power>8</power>
								<cooldownTime>1.55</cooldownTime>
								<armorPenetrationBlunt>2.755</armorPenetrationBlunt>
								<linkedBodyPartsGroup>Muzzle</linkedBodyPartsGroup>
							</li>
						</tools>
					</value>
				</li>

				<li Class="CombatExtended.PatchOperationMakeGunCECompatible">
					<defName>DV_Gun_LaserpulseLongrifle</defName>
					<statBases>
						<SightsEfficiency>3</SightsEfficiency>
						<ShotSpread>0.03</ShotSpread>
						<SwayFactor>1.35</SwayFactor>
						<Bulk>13.7</Bulk>
						<Mass>9.7</Mass>
						<RangedWeapon_Cooldown>1.36</RangedWeapon_Cooldown>
					</statBases>
					<costList>
						<Plasteel>70</Plasteel>
						<Uranium>30</Uranium>
						<ComponentSpacer>4</ComponentSpacer>
					</costList>
					<Properties>
						<recoilAmount>0.01</recoilAmount>
						<verbClass>CombatExtended.Verb_ShootCE</verbClass>
						<hasStandardCommand>true</hasStandardCommand>
						<defaultProjectile>Bullet_Laser_LaserpulseLongrifle</defaultProjectile>
						<warmupTime>1.8</warmupTime>
						<range>88</range>
						<soundCast>DV_Shot_PhotonSMG</soundCast>
						<soundCastTail>GunTail_Heavy</soundCastTail>
						<muzzleFlashScale>12</muzzleFlashScale>
						<ammoConsumedPerShotCount>10</ammoConsumedPerShotCount>
					</Properties>
					<AmmoUser>
						<magazineSize>50</magazineSize>
						<reloadTime>4</reloadTime>
						<ammoSet>AmmoSet_LaserpulseLongrifle</ammoSet>
					</AmmoUser>
					<FireModes>
						<aiAimMode>AimedShot</aiAimMode>
					</FireModes>
					<weaponTags>
						<li>CE_AI_SR</li>
						<li>Bipod_AMR</li>
						<li>Longrifle</li>
					</weaponTags>
				</li>

				<li Class="PatchOperationAddModExtension">
				  <xpath>Defs/ThingDef[defName="DV_Gun_LaserpulseLongrifle"]</xpath>
					  <value>
						  <li Class="EBSGFramework.EquipRestrictExtension">
							<requiredGenesToEquip>
								<li>DV_Farsighted</li>
							</requiredGenesToEquip>
						  </li>
					  </value>
				</li>

				<li Class="PatchOperationAdd">
				  <xpath>Defs/ThingDef[defName="DV_Gun_LaserpulseLongrifle"]</xpath>
					<value>
						<equippedAngleOffset>45</equippedAngleOffset>
					</value>
				</li>

			</operations>
		</match>
	</Operation>
	
</Patch>