			<Mass>14.0</Mass>
			<Bulk>21.0</Bulk>
			<SwayFactor>1.35</SwayFactor>
			<ShotSpread>0.05</ShotSpread>
			<SightsEfficiency>0.75</SightsEfficiency>
			<RangedWeapon_Cooldown>0.56</RangedWeapon_Cooldown>
		</statBases>
