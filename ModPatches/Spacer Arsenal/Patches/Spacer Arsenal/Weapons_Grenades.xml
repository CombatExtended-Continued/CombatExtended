		</nomatch>
	</Operation>
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="DV_Proj_GrenadeShatter"]/comps</xpath>
		<value>
			<li Class="CombatExtended.CompProperties_Fragments">
				<fragments>
					<Fragment_Small>14</Fragment_Small>
				</fragments>
			</li>
		</value>
	</Operation>

