	<Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[defName="DV_Proj_GrenadeShatter"]/projectile</xpath>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="DV_Proj_GrenadeShatter"]</xpath>
		<value>
			<projectile Class="CombatExtended.ProjectilePropertiesCE">
				<explosionRadius>2.3</explosionRadius>
				<damageDef>Bomb</damageDef>
				<damageAmountBase>56</damageAmountBase>
				<explosionDelay>0</explosionDelay>
				<dropsCasings>true</dropsCasings>
				<casingMoteDefname>Fleck_GrenadePin</casingMoteDefname>
				<casingFilthDefname>Filth_GrenadeAmmoCasings</casingFilthDefname>
				<applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
				<speed>12</speed>
				<suppressionFactor>3.0</suppressionFactor>
				<dangerFactor>2.0</dangerFactor>
				<airborneSuppressionFactor>0.25</airborneSuppressionFactor>
				<ballisticCoefficient>2.0~2.0</ballisticCoefficient>
				<mass>400~400</mass>
				<diameter>64~64</diameter>
			</projectile>
		</value>
	</Operation>

	<Operation Class="PatchOperationConditional">
		<xpath>Defs/ThingDef[defName="DV_Proj_GrenadeShatter"]/comps</xpath>
