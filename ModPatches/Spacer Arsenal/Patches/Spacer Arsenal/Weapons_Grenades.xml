	<!-- Contact Grenades -->

	<!-- Projectile -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="DV_Proj_GrenadeShatter"]/thingClass</xpath>
		<value>
			<thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
		</value>
