<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- === Quickdraw === -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="USH_UpgradeSpeed"]/comps/li[@Class="USH_GE.CompProperties_OverclockUpgrade"]/statOffsets</xpath>
		<value>
			<statOffsets>
				<AimingDelayFactor>-0.1</AimingDelayFactor>
				<ReloadSpeed>0.15</ReloadSpeed>
			</statOffsets>
		</value>
	</Operation>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Odyssey</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>

				<!-- ADP rounds -->
				<li Class="PatchOperationReplace">
					<xpath>Defs/WeaponTraitDef[defName="USH_ADPRounds"]/damageDefOverride</xpath>
					<value>
						<extraDamages>
							<li>
								<def>USH_ADP</def>
								<amount>3</amount>
							</li>
						</extraDamages>
					</value>
				</li>

			</operations>
		</match>
	</Operation>
</Patch>