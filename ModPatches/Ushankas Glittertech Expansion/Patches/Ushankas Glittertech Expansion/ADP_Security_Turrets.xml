<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ========== ADP chain pylon ========== -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="USH_Turret_ADP"]/statBases/ShootingAccuracyTurret</xpath>
		<value>
			<ShootingAccuracyTurret>1.0</ShootingAccuracyTurret>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="USH_Turret_ADP"]/statBases/Mass</xpath>
		<value>
			<Mass>60</Mass>
			<Bulk>25</Bulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[defName="USH_Turret_ADP"]/comps/li[@Class = "CompProperties_Explosive"]</xpath>
	</Operation>

	<!-- ========== ADP chain pylon ========== -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs</xpath>
		<value>
			<ThingDef ParentName="BaseBullet">
				<defName>USH_ChainBoltCE</defName>
				<label>ADP chain bolt</label>
				<thingClass>VEF.Weapons.TeslaProjectile</thingClass>
				<drawOffscreen>true</drawOffscreen>
				<graphicData>
					<texPath>Effects/Staticlord/ChainBolt</texPath>
					<graphicClass>Graphic_Flicker</graphicClass>
					<shaderType>TransparentPostLight</shaderType>
				</graphicData>
				<projectile>
					<damageDef>Stun</damageDef>
					<damageAmountBase>1</damageAmountBase>
					<speed>140</speed>
				</projectile>
				<comps>
					<li>
						<compClass>VEF.Abilities.CompAbilityProjectile</compClass>
					</li>
				</comps>
				<modExtensions>
					<li Class="VEF.Weapons.TeslaChainingProps">
						<maxBounceCount>4</maxBounceCount>
						<damageDef>Smoke</damageDef>
						<explosionDamageDef>USH_ADP</explosionDamageDef>
						<impactRadius>3</impactRadius>
						<targetFriendly>false</targetFriendly>
						<addFire>true</addFire>
						<bounceRange>12</bounceRange>
						<maxLifetime>50</maxLifetime>
					</li>
				</modExtensions>
			</ThingDef>
		</value>
	</Operation>

	<!-- ========== ADP pylon core ========== -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="USH_Gun_ADPTurret"]/verbs/li/range</xpath>
		<value>
			<range>55</range>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="USH_Gun_ADPTurret"]/verbs/li/defaultProjectile</xpath>
		<value>
			<defaultProjectile>USH_ChainBoltCE</defaultProjectile>
		</value>
	</Operation>

</Patch>