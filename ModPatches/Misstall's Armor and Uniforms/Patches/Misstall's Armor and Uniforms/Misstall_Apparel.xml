		<value>
			<MeleeDodgeChance>0.25</MeleeDodgeChance>
		</value>
	</Operation>
	
	<!--Melee Glove-->
	
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_MUO_2GL"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>2</ArmorRating_Sharp>
			<Bulk>5</Bulk>
