	<!-- === Halo 4 Forerunner Lancer === -->
	<Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
		<defName>HRPPA_PsychicPulseLancer</defName>
		<statBases>
			<Mass>5.20</Mass>
			<Bulk>15.00</Bulk>
