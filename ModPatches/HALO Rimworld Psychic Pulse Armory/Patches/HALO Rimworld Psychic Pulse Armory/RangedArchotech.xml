	<!-- === Halo 4 Forerunner Spinner === -->
	<Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
		<defName>HRPPA_PsychicPulseSpinner</defName>
		<statBases>
			<Mass>3.8</Mass>
			<Bulk>10.40</Bulk>
			<SwayFactor>2.64</SwayFactor>
			<ShotSpread>0.06</ShotSpread>
			<SightsEfficiency>1.1</SightsEfficiency>
			<RangedWeapon_Cooldown>0.36</RangedWeapon_Cooldown>
		</statBases>
		<Properties>
			<verbClass>CombatExtended.Verb_ShootCE</verbClass>
			<hasStandardCommand>True</hasStandardCommand>
			<defaultProjectile>HRPPA_Bullet_PsychicPulseSpinnerCE</defaultProjectile>
			<burstShotCount>25</burstShotCount>
			<ticksBetweenBurstShots>1</ticksBetweenBurstShots>
			<warmupTime>2</warmupTime>
			<range>75</range>
			<soundCast>HRPPA_Shot_PsychicPulseSpinner</soundCast>
			<soundCastTail>GunTail_Medium</soundCastTail>
			<muzzleFlashScale>12</muzzleFlashScale>
			<recoilAmount>0.01</recoilAmount>
			<recoilPattern>Regular</recoilPattern>
			<stopBurstWithoutLos>false</stopBurstWithoutLos>
		</Properties>
		<AmmoUser>
			<magazineSize>250</magazineSize>
			<reloadTime>6</reloadTime>
		</AmmoUser>
		<FireModes>
			<aiAimMode>SuppressFire</aiAimMode>
			<aimedBurstShotCount>10</aimedBurstShotCount>
			<noSingleShot>true</noSingleShot>
		</FireModes>
		<weaponTags>
			<li>ArchotechWeapons</li>
			<li>HRPPAGun</li>
		</weaponTags>
	</Operation>

	<Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[defName="HRPPA_PsychicPulseGrenade"]/verbs</xpath>
	</Operation>

	<Operation Class="PatchOperationConditional">
		<xpath>Defs/ThingDef[defName="HRPPA_PsychicPulseGrenade"]/comps</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/ThingDef[defName="HRPPA_PsychicPulseGrenade"]</xpath>
			<value>
				<comps />
			</value>
		</nomatch>
	</Operation>

	<Operation Class="PatchOperationAttributeSet">
		<xpath>Defs/ThingDef[defName="HRPPA_PsychicPulseGrenade"]</xpath>
		<attribute>Class</attribute>
		<value>CombatExtended.AmmoDef</value>
	</Operation>

	<Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
		<defName>HRPPA_PsychicPulseGrenade</defName>
		<statBases>
			<MarketValue>16</MarketValue>
			<Mass>0.4</Mass>
			<Bulk>0.87</Bulk>
			<SightsEfficiency>1</SightsEfficiency>
			<RangedWeapon_Cooldown>2.66</RangedWeapon_Cooldown>
		</statBases>
		<Properties>
			<verbClass>CombatExtended.Verb_ShootCEOneUse</verbClass>
			<hasStandardCommand>true</hasStandardCommand>
			<defaultProjectile>HRPPA_Proj_PsychicPulseGrenadeCE</defaultProjectile>
			<warmupTime>0.85</warmupTime>
			<range>16</range>
			<ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
			<onlyManualCast>true</onlyManualCast>
			<ignorePartialLoSBlocker>true</ignorePartialLoSBlocker>
			<noiseRadius>4</noiseRadius>
			<soundCast>ThrowGrenade</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		</Properties>
		<weaponTags>
			<li>CE_AI_Grenade</li>
			<li>CE_OneHandedWeapon</li>
			<li>ArchotechWeapons</li>
			<li>HRPPAGun</li>
		</weaponTags>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="HRPPA_PsychicPulseGrenade"]/comps</xpath>
		<value>
			<li Class="CombatExtended.CompProperties_ExplosiveCE">
				<explosiveDamageType>Neuralizer_weak</explosiveDamageType>
				<explosiveRadius>6.66</explosiveRadius>
			</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="HRPPA_PsychicPulseGrenade"]</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>handle</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>12</power>
					<cooldownTime>1</cooldownTime>
					<armorPenetrationSharp>0.55</armorPenetrationSharp>
					<armorPenetrationBlunt>0.55</armorPenetrationBlunt>
					<linkedBodyPartsGroup>Handle</linkedBodyPartsGroup>
				</li>
			</tools>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="HRPPA_PsychicPulseGrenade"]</xpath>
		<value>
			<thingClass>CombatExtended.AmmoThing</thingClass>
			<stackLimit>75</stackLimit>
			<resourceReadoutPriority>First</resourceReadoutPriority>
		</value>
	</Operation>


</Patch>