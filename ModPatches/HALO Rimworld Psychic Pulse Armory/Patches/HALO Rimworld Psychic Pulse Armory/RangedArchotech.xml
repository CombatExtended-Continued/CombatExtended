	<!-- === Halo 4 Forerunner Scatter === -->
	<Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
		<defName>HRPPA_PsychicPulseScatter</defName>
		<statBases>
			<Mass>4.40</Mass>
			<Bulk>11.00</Bulk>
			<SwayFactor>1.24</SwayFactor>
			<ShotSpread>0.06</ShotSpread>
			<SightsEfficiency>1.10</SightsEfficiency>
			<RangedWeapon_Cooldown>0.38</RangedWeapon_Cooldown>
		</statBases>
		<Properties>
			<recoilAmount>0.01</recoilAmount>
			<verbClass>CombatExtended.Verb_ShootCE</verbClass>
			<hasStandardCommand>True</hasStandardCommand>
			<defaultProjectile>HRPPA_Bullet_PsychicPulseShotgunCE</defaultProjectile>
			<warmupTime>0.5</warmupTime>
			<range>17</range>
			<soundCast>HRPPA_Shot_PsychicPulseScatter</soundCast>
			<soundCastTail>GunTail_Medium</soundCastTail>
			<muzzleFlashScale>9</muzzleFlashScale>
			<stopBurstWithoutLos>false</stopBurstWithoutLos>
		</Properties>
		<AmmoUser>
