		<defName>HRPPA_PsychicPulseReacher</defName>
		<statBases>
			<Mass>4.80</Mass>
			<Bulk>13.00</Bulk>
			<SwayFactor>1.19</SwayFactor>
			<ShotSpread>0.04</ShotSpread>
