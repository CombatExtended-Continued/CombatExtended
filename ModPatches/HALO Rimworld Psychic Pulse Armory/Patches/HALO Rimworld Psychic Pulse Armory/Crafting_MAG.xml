<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>More Archotech Garbage (Continued)</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>

				<!--=== ArchotechCrafting ===-->
				<li Class="PatchOperationReplace">
					<xpath>Defs/RecipeDef[defName="MakeArchotechHaloWeaponG"]/label</xpath>
					<value>
						<label>make 60 psychic pulse detonators</label>
					</value>
				</li>

				<li Class="PatchOperationReplace">
					<xpath>Defs/RecipeDef[defName="MakeArchotechHaloWeaponG"]/description</xpath>
					<value>
						<description>Make 60 psychic pulse detonators.</description>
					</value>
				</li>

				<li Class="PatchOperationReplace">
					<xpath>Defs/RecipeDef[defName="MakeArchotechHaloWeaponG"]/products</xpath>
					<value>
						<products>
							<HRPPA_PsychicPulseGrenade>60</HRPPA_PsychicPulseGrenade>
						</products>
					</value>
				</li>

			</operations>
		</match>
	</Operation>
</Patch>
         