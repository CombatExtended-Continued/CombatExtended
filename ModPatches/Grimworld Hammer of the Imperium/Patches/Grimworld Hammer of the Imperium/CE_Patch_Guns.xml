<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<!--Melee Attacks for Guns-->
	<Operation Class="PatchOperationReplace">
		<xpath>
			Defs/ThingDef[
			defName="GW_HOI_Gun_PlasmaGun" or 
			defName="GW_HOI_Gun_MeltaGun" or 
			defName="GW_HOI_Gun_Kantrael" or 
			defName="GW_HOI_Gun_Hellgun" or
			defName="GW_HOI_Gun_Longlas" or
			defName="GW_HOI_Gun_Agripinaamkii" or
			defName="GW_HOI_Gun_Agripinaamkiitanker" or
			defName="GW_HOI_Shotgun" or
			defName="GW_HOI_Gun_Bolter" or 
			defName="GW_HOI_Gun_Flamer"
			]/tools
		</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>barrel</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>5</power>
					<cooldownTime>2.02</cooldownTime>
					<armorPenetrationBlunt>1.63</armorPenetrationBlunt>
					<linkedBodyPartsGroup>Barrel</linkedBodyPartsGroup>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>stock</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>8</power>
					<cooldownTime>1.55</cooldownTime>
					<chanceFactor>1.5</chanceFactor>
					<armorPenetrationBlunt>2.755</armorPenetrationBlunt>
					<linkedBodyPartsGroup>Stock</linkedBodyPartsGroup>
				</li>
			</tools>
		</value>
	</Operation>
