			<Bulk>1.5</Bulk>
			<WornBulk>0.5</WornBulk>
			<ArmorRating_Sharp>0.16</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.32</ArmorRating_Blunt>
		</value>
	</Operation>

