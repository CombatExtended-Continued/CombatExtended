<Patch>

	<!-- Disintegrator -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/AbilityDef[defName="GR_Disintegrator"]/verbProperties</xpath>
		<value>
			<verbProperties Class="CombatExtended.VerbPropertiesCE">
				<verbClass>CombatExtended.Verb_AbilityShootCE</verbClass>
				<defaultProjectile>GR_Disintegrator</defaultProjectile>
				<range>100</range>
				<muzzleFlashScale>15</muzzleFlashScale>
				<warmupTime>0.2</warmupTime>
				<soundCast>GR_DisintegratorSound</soundCast>
				<burstShotCount>1</burstShotCount>
				<ticksBetweenBurstShots>2</ticksBetweenBurstShots>
				<minRange>1</minRange>
				<targetParams>
					<canTargetPawns>true</canTargetPawns>
				</targetParams>
				<ai_IsWeapon>false</ai_IsWeapon>
			</verbProperties>
		</value>
	</Operation>

