<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ========== LifeSupportPack ========== -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="LifeSupportPack"]/statBases/Mass</xpath>
		<value>
			<Mass>4</Mass>
			<Bulk>8</Bulk>
			<WornBulk>4</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="LifeSupportPack"]/equippedStatOffsets/MoveSpeed</xpath>
		<value>
			<SmokeSensitivity>-1</SmokeSensitivity>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="LifeSupportPack"]/apparel/bodyPartGroups</xpath>
		<value>
			<bodyPartGroups>
				<li>Shoulders</li>
			</bodyPartGroups>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="LifeSupportPack"]/apparel/layers</xpath>
		<value>
			<layers>
				<li>Backpack</li>
			</layers>
		</value>
	</Operation>

</Patch>