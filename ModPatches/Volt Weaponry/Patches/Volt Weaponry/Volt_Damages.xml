<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/DamageDef[defName="DV_WattDamage"]/label</xpath>
		<value>
			<label>electric thermal laser</label>
		</value>
	</Operation>

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/DamageDef[defName="DV_WattDamage"]</xpath>
		<value>
			<li Class="CombatExtended.DamageDefExtensionCE">
				<isAmbientDamage>true</isAmbientDamage>
			</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/DamageDef[defName="DV_WattDamage"]</xpath>
		<value>
			<buildingDamageFactor>0.25</buildingDamageFactor>
		</value>
	</Operation>

</Patch>