<?xml version="1.0" encoding="utf-8"?>
<Patch>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[@Name="DV_ApparelOutlawHelmetBase"]/statBases/ArmorRating_Sharp</xpath>
        <value>
            <Bulk>4</Bulk>
            <WornBulk>1</WornBulk>
            <StuffEffectMultiplierArmor>4</StuffEffectMultiplierArmor>
            <ArmorRating_Sharp>2</ArmorRating_Sharp>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[@Name="DV_ApparelOutlawHelmetBase"]/statBases/ArmorRating_Blunt</xpath>
        <value>
            <ArmorRating_Blunt>1.5</ArmorRating_Blunt>
        </value>
    </Operation>

    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ThingDef[@Name="DV_ApparelOutlawHelmetBase"]/statBases/ArmorRating_Heat</xpath>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[@Name="DV_ApparelOutlawHelmetBase"]/statBases/Mass</xpath>
        <value>
            <Mass>3</Mass>
        </value>
    </Operation>

    <!-- Partial armor coverage; collar is thinner. -->
    <Operation Class="PatchOperationAddModExtension">
        <xpath>Defs/ThingDef[@Name="DV_ApparelOutlawHelmetBase"]</xpath>
        <value>
            <li Class="CombatExtended.PartialArmorExt">
                <stats>
                    <li>
                        <ArmorRating_Sharp>0.40</ArmorRating_Sharp>
                        <parts>
                            <li>Eye</li>
                        </parts>
                    </li>
                    <li>
                        <ArmorRating_Blunt>0.40</ArmorRating_Blunt>
                        <parts>
                            <li>Eye</li>
                        </parts>
                    </li>
                    <li>
                        <ArmorRating_Sharp>0.10</ArmorRating_Sharp>
                        <parts>
                            <li>Nose</li>
                            <li>Jaw</li>
                        </parts>
                    </li>
                    <li>
                        <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
                        <parts>
                            <li>Nose</li>
                            <li>Jaw</li>
                        </parts>
                    </li>
                </stats>
            </li>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[@Name="DV_ApparelOutlawHelmetBase"]/statBases/Insulation_Cold</xpath>
        <value>
            <StuffEffectMultiplierInsulation_Cold>0.8</StuffEffectMultiplierInsulation_Cold>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[@Name="DV_ApparelOutlawHelmetBase"]/statBases/Insulation_Heat</xpath>
        <value>
            <StuffEffectMultiplierInsulation_Heat>0.3</StuffEffectMultiplierInsulation_Heat>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[@Name="DV_ApparelOutlawHelmetBase"]/costList/Steel</xpath>
        <value>
            <Cloth>20</Cloth>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[@Name="DV_ApparelOutlawHelmetBase"]/stuffCategories</xpath>
        <value>
            <stuffCategories>
                <li>Steeled</li>
            </stuffCategories>
        </value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[@Name="DV_ApparelOutlawHelmetBase"]/equippedStatOffsets/RangedCooldownFactor</xpath>
        <value>
            <AimingAccuracy>0.05</AimingAccuracy>
            <SmokeSensitivity>-1</SmokeSensitivity>
        </value>
    </Operation>

    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[@Name="DV_ApparelOutlawHelmetBase"]/apparel/layers</xpath>
        <value>
            <li>OnHead</li>
            <li>StrappedHead</li>
        </value>
    </Operation>

</Patch>