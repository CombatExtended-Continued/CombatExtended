		<label>make volt laser cell x500</label>
		<description>Craft 500 volt laser cell.</description>
		<jobString>Making volt laser cell.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Plasteel</li>
					</thingDefs>
				</filter>
