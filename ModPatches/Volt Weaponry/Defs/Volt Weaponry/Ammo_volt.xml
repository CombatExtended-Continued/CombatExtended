	<!-- ==================== Ammo ========================== -->
	<ThingDef Class="CombatExtended.AmmoDef" ParentName="LaserChargePackBase">
		<defName>Ammo_VoltLaserCellPack</defName>
		<label>volt laser cell</label>
		<graphicData>
			<texPath>ThirdParty/Volt Weaponry/Ammo/VoltBattery</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<ammoClass>Laser</ammoClass>
	</ThingDef>

	<!-- ================== Projectiles ================== -->
	<ThingDef Name="BaseVoltLaser" ParentName="BaseLaserBulletTextured" Abstract="True">
		<label>volt beam</label>
		<graphicData>
			<color>(255,239,85)</color>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<isInstant>true</isInstant>
			<damageDef>DV_WattDamage</damageDef>
		</projectile>
		<modExtensions>
			<li Class="ProjectileImpactFX.EffectProjectileExtension">
				<AutoAssign>true</AutoAssign>
				<CreateTerrainEffects>false</CreateTerrainEffects>
				<explosionFleckDef>Fleck_HeatGlow_API</explosionFleckDef>
				<explosionFleckSize>1</explosionFleckSize>
				<ImpactGlowFleckDef>ExplosionFlash</ImpactGlowFleckDef>
				<ImpactGlowFleckSize>2.5</ImpactGlowFleckSize>
			</li>
		</modExtensions>
	</ThingDef>

	<ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" ParentName="BaseVoltLaser">
		<defName>Bullet_VoltLaserLow</defName>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageAmountBase>14</damageAmountBase>
			<armorPenetrationSharp>0.001</armorPenetrationSharp>
			<armorPenetrationBlunt>0.001</armorPenetrationBlunt>
			<armorPenetrationBase>0.1</armorPenetrationBase>
			<secondaryDamage>
				<li>
					<def>Electrical</def>
					<amount>5</amount>
				</li>
			</secondaryDamage>
		</projectile>
	</ThingDef>

