<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- ================== Harpoon ================== -->
	
	<CombatExtended.AmmoCategoryDef>
		<defName>CryoHarpoon</defName>
		<label>Cryo Harpoon</label>
		<labelShort>Harpoon</labelShort>
		<description>Metal rods converted for combat use.</description>
	</CombatExtended.AmmoCategoryDef>

	<!-- ==================== AmmoSet ========================== -->
	<CombatExtended.AmmoSetDef>
		<defName>AmmoSet_CryoHarpoon</defName>
		<label>Heavy Cryo Harpoon</label>
		<ammoTypes>
			<Ammo_CryoHarpoon>Bullet_CryoHarpoon</Ammo_CryoHarpoon>
		</ammoTypes>
		<similarTo>AmmoSet_ChargedHeavy</similarTo>
	</CombatExtended.AmmoSetDef>

	<!-- ==================== Ammo ========================== -->	
	<ThingDef Class="CombatExtended.AmmoDef" Name="CryoHarpoon" ParentName="SpacerMediumAmmoBase" Abstract="True">
		<description>Metal javelins tiped with plasteel, for use with Cryo Harpoon launcher.</description>
		<statBases>
			<Mass>2</Mass>
			<Bulk>1.21</Bulk>
		</statBases>
		<tradeTags>
			<li>CE_AutoEnableTrade</li>
			<li>CE_AutoEnableCrafting_FabricationBench</li>
		</tradeTags>
		<thingCategories>
			<li>AmmoHighCaliber</li>
		</thingCategories>
		<stackLimit>50</stackLimit>
	</ThingDef>

	<ThingDef Class="CombatExtended.AmmoDef" ParentName="CryoHarpoon">
		<defName>Ammo_CryoHarpoon</defName>
		<label>Heavy Cryo Harpoon</label>
		<graphicData>
			<texPath>Things/Ammo/Cryo_Harpoon</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<statBases>
			<MarketValue>9.94</MarketValue>
		</statBases>
		<ammoClass>CryoHarpoon</ammoClass>
	</ThingDef>

	<!-- ================== Projectiles ================== -->
	<ThingDef Name="BaseCryoHarpoon" ParentName="BaseBulletCE" Abstract="true">
		<graphicData>
			<texPath>Things/Projectiles/Proj_Harpoon</texPath>
			<shaderType>TransparentPostLight</shaderType>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(0.65, 1.3)</drawSize>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>VQE_CryptoCut</damageDef>
			<speed>140</speed>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="BaseCryoHarpoon">
		<defName>Bullet_CryoHarpoon</defName>
		<label>Heavy Cryo Harpoon</label>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageAmountBase>55</damageAmountBase>
			<armorPenetrationSharp>30</armorPenetrationSharp>
			<armorPenetrationBlunt>400</armorPenetrationBlunt>
		</projectile>
	</ThingDef>

	<!-- ==================== Recipes ========================== -->
	<RecipeDef ParentName="AmmoRecipeBase">
		<defName>MakeAmmo_CryoHarpoon</defName>
		<label>make Heavy Cryo x25</label>
		<description>Craft 25 Cryo Harpoon.</description>
		<jobString>Making Cryo Harpoon.</jobString>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>88</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Plasteel</li>
					</thingDefs>
				</filter>
				<count>12</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Steel</li>
				<li>Plasteel</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<Ammo_CryoHarpoon>25</Ammo_CryoHarpoon>
		</products>
		<workAmount>10000</workAmount>
	</RecipeDef>
	
</Defs>