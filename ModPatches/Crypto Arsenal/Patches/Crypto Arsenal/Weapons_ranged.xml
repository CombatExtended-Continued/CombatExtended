		<Properties>
			<recoilAmount>9.44</recoilAmount>
			<verbClass>CombatExtended.Verb_ShootCE</verbClass>
			<hasStandardCommand>true</hasStandardCommand>
			<defaultProjectile>Bullet_CryoHarpoon</defaultProjectile>
