<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<!-- Crypto Shield -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="CAT_CryptoHeavyShield"]</xpath>
		<value>

			<ThingDef ParentName="ShieldBase">
				<defName>CAT_CryptoHeavyShield</defName>
				<label>cryo tower shield</label>
				<description>A heavy cryo-tech shield provides great protection against bullet with decent amount of blunt and heat.</description>
				<techLevel>Ultra</techLevel>
				<graphicData>
					<texPath>Things/Items/Equipment/Shield/CryptoHeavyShield</texPath>
					<graphicClass>Graphic_Single</graphicClass>
					<drawSize>1.2</drawSize>
				</graphicData>
				<thingClass>CombatExtended.Apparel_Shield</thingClass>
				<thingCategories Inherit="False">
					<li>VFEC_Shields</li>
				</thingCategories>
				<recipeMaker Inherit="False" />
				<costList>
					<Plasteel>250</Plasteel>
					<ComponentSpacer>10</ComponentSpacer>
				</costList>
				<statBases>
					<MaxHitPoints>500</MaxHitPoints>
					<Flammability>0</Flammability>
					<ArmorRating_Sharp>75</ArmorRating_Sharp>
					<ArmorRating_Blunt>25</ArmorRating_Blunt>
					<ArmorRating_Heat>0.5</ArmorRating_Heat>
					<WorkToMake>2600</WorkToMake>
					<Mass>8.5</Mass>
					<Bulk>14</Bulk>
					<WornBulk>8</WornBulk>
				</statBases>
				<equippedStatOffsets>
					<ReloadSpeed>-0.15</ReloadSpeed>
					<MeleeHitChance>-1</MeleeHitChance>
					<ShootingAccuracyPawn>-0.4</ShootingAccuracyPawn>
					<AimingAccuracy>-0.1</AimingAccuracy>
					<Suppressability>-0.25</Suppressability>
					<MeleeCritChance>-0.08</MeleeCritChance>
					<MeleeParryChance>1.0</MeleeParryChance>
				</equippedStatOffsets>
				<apparel>
					<tags>
						<li>VikingShield_Basic</li>
					</tags>
				</apparel>
				<modExtensions>
					<li Class="CombatExtended.ShieldDefExtension">
						<shieldCoverage>
							<li>Hands</li>
							<li>Arms</li>
							<li>Shoulders</li>
							<li>Torso</li>
							<li>Neck</li>
							<li>FullHead</li>
						</shieldCoverage>
						<crouchCoverage>
							<li>Legs</li>
							<li>Feet</li>
						</crouchCoverage>
						<drawAsTall>true</drawAsTall>
					</li>
				</modExtensions>
			</ThingDef>

		</value>
	</Operation>

</Patch>