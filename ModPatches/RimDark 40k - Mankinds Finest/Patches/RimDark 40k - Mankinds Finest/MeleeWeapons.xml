<?xml version="1.0" encoding="UTF-8"?>
<Patch>
    <!--Power Sword-->
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="BEWH_AstartesPowerSword"]</xpath>
        <value>
            <statBases>
                <Bulk>10</Bulk>
                <MeleeCounterParryBonus>1.5</MeleeCounterParryBonus>
            </statBases>
            <equippedStatOffsets>
                <MeleeCritChance>1.0</MeleeCritChance>
                <MeleeParryChance>0.75</MeleeParryChance>
                <MeleeDodgeChance>0.5</MeleeDodgeChance>
            </equippedStatOffsets>
            <weaponTags>
                <li>CE_OneHandedWeapon</li>
            </weaponTags>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>
            Defs/ThingDef[defName="BEWH_AstartesPowerSword"]/tools</xpath>
        <value>
            <tools>
                <li Class="CombatExtended.ToolCE">
                    <label>edge</label>
                    <capacities>
                        <li>Cut</li>
                    </capacities>
                    <power>58</power>
                    <extraMeleeDamages>
                        <li>
                            <def>EMP</def>
                            <amount>2</amount>
                        </li>
                    </extraMeleeDamages>
                    <cooldownTime>2.2</cooldownTime>
                    <armorPenetrationBlunt>6</armorPenetrationBlunt>
                    <armorPenetrationSharp>40</armorPenetrationSharp>
                    <soundMeleeHit>BEWH_SFX_PowerswordHit</soundMeleeHit>
                </li>
                <li Class="CombatExtended.ToolCE">
                    <label>handle</label>
                    <capacities>
                        <li>Blunt</li>
                    </capacities>
                    <power>36</power>
                    <cooldownTime>2.2</cooldownTime>
                    <armorPenetrationBlunt>40</armorPenetrationBlunt>
                    <soundMeleeHit>BEWH_SFX_PowerswordHit</soundMeleeHit>
                </li>
            </tools>
        </value>
    </Operation>


