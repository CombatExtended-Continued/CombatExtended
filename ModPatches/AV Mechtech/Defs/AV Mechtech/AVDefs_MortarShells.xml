	<!-- Waste Shell Ammo Definition -->
	<ThingDef Class="CombatExtended.AmmoDef" ParentName="81mmMortarShellBaseCraftableBase">
		<defName>Shell_81mmMortar_Waste</defName>
		<label>waster shell</label>
		<description>An artillery shell containing compressed toxic waste. When fired, it will stick into the ground and pollute the area while releasing tox gas for some time
			before
			expiring.

			Tox gas burns the lungs and eyes, causing a temporary shortness of breath and reduction in sight. Continued exposure to tox gas results in toxic buildup that can be
			lethal.</description>
		<graphicData>
			<texPath>Things/Item/Resource/Shell/AV_ShellWaster</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<statBases>
			<Mass>5</Mass>
			<Bulk>8.34</Bulk>
		</statBases>
		<ammoClass>AV_Toxic</ammoClass>
		<detonateProjectile>Bullet_81mmMortarShell_Waster</detonateProjectile>
		<comps>
			<li Class="CompProperties_Dissolution">
				<dissolutionAfterDays>150</dissolutionAfterDays>
				<dissolutinFactorIndoors>0.1</dissolutinFactorIndoors>
				<!-- instantly explodes when on 0-->
				<dissolutionFactorRain>2</dissolutionFactorRain>
			</li>
			<li Class="CompProperties_DissolutionEffectPollution">
				<cellsToPollutePerDissolution>18</cellsToPollutePerDissolution>
				<tilePollutionPerDissolution>0.0005</tilePollutionPerDissolution>
				<waterTilePollutionFactor>24</waterTilePollutionFactor>
			</li>
			<li Class="CompProperties_GasOnDamage">
				<type>ToxGas</type>
				<damageFactor>6</damageFactor>
				<useStackCountAsFactor>true</useStackCountAsFactor>
			</li>
			<li>
				<compClass>CompDissolutionEffect_Goodwill</compClass>
			</li>
		</comps>
	</ThingDef>

	<!-- Mechanoid Deployment Shell Ammo Definition -->
	<ThingDef Class="CombatExtended.AmmoDef" ParentName="81mmMortarShellBaseCraftableBase">
		<defName>Shell_81mmMortar_Deployment</defName>
		<label>mechanoid deployment shell</label>
		<description>A shell filled with a sleeping warurchin. On impact it will activate and hunt down any hostile creatures. While this makes a good surprise attack, their data
			processing is limited which makes them see nearly everybody as hostile.</description>
		<graphicData>
			<texPath>Things/Item/Resource/Shell/AV_ShellDeployment</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<statBases>
			<Mass>5</Mass>
			<Bulk>8.34</Bulk>
		</statBases>
		<ammoClass>AV_Deployment</ammoClass>
		<detonateProjectile>Bullet_81mmMortarShell_Deployment</detonateProjectile>
		<tradeTags>
			<li>AV_Mechtech</li>
			<li>AV_Mechtech_Spacer</li>
		</tradeTags>
	</ThingDef>

