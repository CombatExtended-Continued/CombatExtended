	<ThingDef ParentName="Base81mmMortarShellUtilityDirectfire">
		<defName>Bullet_81mmMortarShell_UtilityDirectfire_Firefoam</defName>
		<label>81mm mortar shell (Foam)</label>
		<graphicData>
			<texPath>Things/Projectile/Mortar/Firefoam</texPath>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>Extinguish</damageDef>
			<suppressionFactor>0.0</suppressionFactor>
