	<!-- Mechanoid Deployment Shell Projectile (Proper Pawn Spawning Implementation) -->
	<ThingDef ParentName="Base81mmMortarShell">
		<defName>Bullet_81mmMortarShell_Deployment</defName>
		<label>mechanoid deployment shell</label>
		<thingClass>CombatExtended.ProjectileCE_SpawnPawnkind</thingClass>
		<graphicData>
			<texPath>Things/Projectile/ShellHighExplosive</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>TransparentPostLight</shaderType>
