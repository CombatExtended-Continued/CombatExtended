<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<CombatExtended.AmmoCategoryDef>
		<defName>AV_Toxic</defName>
		<label>Toxic</label>
		<description>Filled with tox gas, a caustic agent that burns the lungs and eyes. Continued exposure to it results in toxic buildup which can be lethal.</description>
		<advanced>true</advanced>
	</CombatExtended.AmmoCategoryDef>

	<CombatExtended.AmmoCategoryDef>
		<defName>AV_Deployment</defName>
		<label>Deployment</label>
		<description>A shell containing with a dormant warurchin. It will activate on impact and attack any nearby creatures.</description>
		<advanced>true</advanced>
	</CombatExtended.AmmoCategoryDef>

	<!-- Ammo Set -->
	<CombatExtended.AmmoSetDef>
		<defName>AmmoSet_81mmMortarShell_Utilitydirectfire</defName>
