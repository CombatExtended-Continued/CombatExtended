<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Royalty</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>

				<li Class="PatchOperationRemove">
					<xpath>Defs/ThingDef[defName="AV_Turret_AutoMortar_Deployer" or defName="AV_Turret_AutoMortar_Waster" or defName="AV_Artillery_AutoMortar_Deployer" or defName="AV_Artillery_AutoMortar_Waster"]</xpath>
				</li>

				<li Class="PatchOperationAdd">
					<xpath>Defs/CombatExtended.AmmoSetDef[defName="AmmoSet_81mmMortarShell"]/ammoTypes</xpath>
					<value>
						<Shell_81mmMortar_Waste>Bullet_81mmMortarShell_Waster</Shell_81mmMortar_Waste>
						<Shell_81mmMortar_Deployment>Bullet_81mmMortarShell_Deployment</Shell_81mmMortar_Deployment>
					</value>
				</li>

			</operations>
		</match>
	</Operation>


</Patch>