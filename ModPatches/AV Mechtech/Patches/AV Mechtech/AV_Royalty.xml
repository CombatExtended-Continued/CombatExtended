<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Royalty</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>

				<li Class="PatchOperationRemove">
					<xpath>Defs/ThingDef[defName="AV_Turret_AutoMortar_Deployer" or defName="AV_Turret_AutoMortar_Waster" or defName="AV_Artillery_AutoMortar_Deployer" or defName="AV_Artillery_AutoMortar_Waster"]</xpath>
				</li>

				<li Class="PatchOperationAdd">
					<xpath>Defs/CombatExtended.AmmoSetDef[defName="AmmoSet_66mmThermalBolt"]/ammoTypes</xpath>
					<value>
						<AV_Shell_Waste>AV_Bullet_Shell_Waster</AV_Shell_Waste>
						<AV_Shell_Mechanoid_Deployment>AV_Bullet_Mechanoid_Deployment_Shell</AV_Shell_Mechanoid_Deployment>
					</value>
				</li>

			</operations>
		</match>
	</Operation>


</Patch>