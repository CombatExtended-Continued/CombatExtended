<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<!-- Basic helmet operations -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
				defName="PF_ExoVisor"
				]/statBases</xpath>
		<value>
			<Bulk>0.5</Bulk>
			<WornBulk>0.5</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
				defName="PF_SCH_Sentinel" or
				defName="PF_HDH_Golem" or
				defName="PF_HSH_Spectrum"
				]/statBases</xpath>
		<value>
			<Bulk>6</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
				defName="PF_HDH_Golem" or
				defName="PF_HSH_Spectrum"
				]/statBases</xpath>
		<value>
			<NightVisionEfficiency_Apparel>0.75</NightVisionEfficiency_Apparel>
		</value>
	</Operation>

	<!-- Smoke/tox protection -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
				defName="PF_Exopack" or
				defName="PF_ExoHelmet" or
				defName="PF_SCH_Sentinel" or
				defName="PF_HDH_Golem" or
				defName="PF_HSH_Spectrum"
				]/equippedStatOffsets</xpath>
		<value>
			<SmokeSensitivity>-1.00</SmokeSensitivity>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
				defName="PFLight_Armor_Warthog" or
				defName="PF_LightArmor_Exotant_ModelF" or
				defName="PF_Medium_Armor_Brasher" or
				defName="PFMedium_Armor_Martikhoras" or
				defName="PF_Medium_Armor_Titan" or
				defName="PF_Heavy_Armor_Centurion" or
				defName="PF_Heavy_Armor_Monolith" or
				defName="PF_Heavy_Armor_Viper"
				]/equippedStatOffsets</xpath>
		<value>
			<ToxicEnvironmentResistance>0.50</ToxicEnvironmentResistance>
		</value>
	</Operation>
	
	<!-- clean up negative movespeed mods -->
	<Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[
				defName="PF_HDH_Golem" or
				defName="PF_Medium_Armor_Titan" or
				defName="PF_Heavy_Armor_Centurion" or
				defName="PF_Heavy_Armor_Monolith"
				]/equippedStatOffsets/MoveSpeed</xpath>
	</Operation>
	
	<!-- set up variable armour coverage extensions -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
				defName="PFLight_Armor_Warthog" or
				defName="PF_LightArmor_Exotant_ModelF"
				]/apparel/bodyPartGroups</xpath>
		<value>
			<li>Hands</li>
			<li>Feet</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/ThingDef[
				defName="PFLight_Armor_Warthog" or
				defName="PF_LightArmor_Exotant_ModelF" or
				defName="PF_Medium_Armor_Brasher" or
				defName="PFMedium_Armor_Martikhoras" or
				defName="PF_Medium_Armor_Titan" or
				defName="PF_Heavy_Armor_Centurion" or
				defName="PF_Heavy_Armor_Monolith" or
				defName="PF_Heavy_Armor_Viper"
				]</xpath>
		<value>
			<li Class="CombatExtended.PartialArmorExt">
				<stats>
					<li>
						<ArmorRating_Sharp>0.90</ArmorRating_Sharp>
						<parts>
							<li>Leg</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.90</ArmorRating_Blunt>
						<parts>
							<li>Leg</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Sharp>0.60</ArmorRating_Sharp>
						<parts>
							<li>Neck</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.60</ArmorRating_Blunt>
						<parts>
							<li>Neck</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Sharp>0.80</ArmorRating_Sharp>
						<parts>
							<li>Arm</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.80</ArmorRating_Blunt>
						<parts>
							<li>Arm</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Sharp>0.30</ArmorRating_Sharp>
						<parts>
							<li>Hand</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.30</ArmorRating_Blunt>
						<parts>
							<li>Hand</li>
						</parts>
					</li>
				</stats>
			</li>
		</value>
	</Operation>
	
	<!-- ========== Exovisor ========== -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_ExoVisor"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>0.01</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="PF_ExoVisor"]/statBases</xpath>
		<value>
			<NightVisionEfficiency_Apparel>0.80</NightVisionEfficiency_Apparel>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_ExoVisor"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>0.01</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_ExoVisor"]/equippedStatOffsets</xpath>
		<value>
			<equippedStatOffsets Inherit="False">
				<AimingDelayFactor>-0.25</AimingDelayFactor>
				<AimingAccuracy>0.6</AimingAccuracy>
				<ShootingAccuracyPawn>1.5</ShootingAccuracyPawn>
			</equippedStatOffsets>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="PF_ExoVisor"]/apparel</xpath>
		<value>
			<layers Inherit="False">
				<li>StrappedHead</li>
			</layers>
		</value>
	</Operation>

	<!-- Viper -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Viper"]/statBases</xpath>
		<value>
			<Bulk>80</Bulk>
			<WornBulk>12</WornBulk>
			<Flammability>0.2</Flammability>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Viper"]/statBases/MaxHitPoints</xpath>
		<value>
			<MaxHitPoints>400</MaxHitPoints>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Viper"]/statBases/Mass</xpath>
		<value>
			<Mass>30</Mass>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Viper"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>16</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Viper"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>34</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Viper"]</xpath>
		<value>
			<equippedStatOffsets>
				<CarryWeight>50</CarryWeight>
				<CarryBulk>8</CarryBulk>
				<MoveSpeed>0.4</MoveSpeed>
			</equippedStatOffsets>
		</value>
	</Operation>

	<!-- ========== Centurion ========== -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Centurion"]/statBases</xpath>
		<value>
			<Bulk>100</Bulk>
			<WornBulk>15</WornBulk>
			<Flammability>0</Flammability>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Centurion"]/statBases/MaxHitPoints</xpath>
		<value>
			<MaxHitPoints>500</MaxHitPoints>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Centurion"]/statBases/Mass</xpath>
		<value>
			<Mass>50</Mass>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Centurion"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>20</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Centurion"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>45</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Centurion"]/equippedStatOffsets</xpath>
		<value>
			<CarryWeight>80</CarryWeight>
			<CarryBulk>10</CarryBulk>
			<ShootingAccuracyPawn>0.15</ShootingAccuracyPawn>
		</value>
	</Operation>

	<!-- Monolith -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Monolith"]/statBases</xpath>
		<value>
			<Bulk>100</Bulk>
			<WornBulk>15</WornBulk>
			<Flammability>0</Flammability>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Monolith"]/statBases/MaxHitPoints</xpath>
		<value>
			<MaxHitPoints>600</MaxHitPoints>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Monolith"]/statBases/Mass</xpath>
		<value>
			<Mass>80</Mass>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Monolith"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>28</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Monolith"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>60</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Monolith"]/equippedStatOffsets</xpath>
		<value>
			<CarryWeight>100</CarryWeight>
			<CarryBulk>20</CarryBulk>
			<ShootingAccuracyPawn>0.15</ShootingAccuracyPawn>		
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_Heavy_Armor_Monolith"]/equippedStatOffsets/MeleeDodgeChance</xpath>
		<value>
			<MeleeDodgeChance>-0.15</MeleeDodgeChance>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="PF_HSH_Spectrum"]/statBases</xpath>
		<value>
			<Bulk>6</Bulk>
			<WornBulk>1</WornBulk>
			<NightVisionEfficiency_Apparel>0.75</NightVisionEfficiency_Apparel>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_HSH_Spectrum"]/statBases/Flammability</xpath>
		<value>
			<Flammability>0</Flammability>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_HSH_Spectrum"]/statBases/Mass</xpath>
		<value>
			<Mass>6.6</Mass>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_HSH_Spectrum"]/statBases/MaxHitPoints</xpath>
		<value>
			<MaxHitPoints>260</MaxHitPoints>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_HSH_Spectrum"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>22</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_HSH_Spectrum"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>50</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="PF_HSH_Spectrum"]</xpath>
		<value>
			<equippedStatOffsets>
				<PsychicSensitivity>-0.2</PsychicSensitivity>
				<AimingAccuracy>0.15</AimingAccuracy>
				<ToxicEnvironmentResistance>0.50</ToxicEnvironmentResistance>
				<SmokeSensitivity>-1</SmokeSensitivity>
			</equippedStatOffsets>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PF_HSH_Spectrum"]/costList/Plasteel</xpath>
		<value>
			<Plasteel>110</Plasteel>
			<DevilstrandCloth>25</DevilstrandCloth>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="PF_HSH_Spectrum"]/apparel</xpath>
		<value>
			<immuneToToxGasExposure>true</immuneToToxGasExposure>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="PF_HSH_Spectrum"]/apparel/layers</xpath>
		<value>
			<li>OnHead</li>
			<li>StrappedHead</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/ThingDef[defName="PF_HSH_Spectrum"]</xpath>
		<value>
			<li Class="CombatExtended.PartialArmorExt">
				<stats>
					<li>
						<ArmorRating_Sharp>0.90</ArmorRating_Sharp>
						<parts>
							<li>Eye</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.90</ArmorRating_Blunt>
						<parts>
							<li>Eye</li>
						</parts>
					</li>
				</stats>
			</li>
		</value>
	</Operation>

</Patch>