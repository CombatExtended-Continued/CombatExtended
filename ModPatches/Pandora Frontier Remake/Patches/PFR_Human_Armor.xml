	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="PF_ExoVisor" or defName="PF_Exopack"]/statBases</xpath>
		<value>
			<Bulk>0.5</Bulk>
			<WornBulk>0.5</WornBulk>
