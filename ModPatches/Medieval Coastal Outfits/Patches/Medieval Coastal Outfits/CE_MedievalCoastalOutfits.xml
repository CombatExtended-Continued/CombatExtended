<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Flower garland -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
			defName = "MCO_Garland"]/statBases</xpath>
		<value>
			<Bulk>0.1</Bulk>
			<WornBulk>0</WornBulk>
		</value>
	</Operation>	

	<!-- Coastal hood -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
			defName = "MCO_CoastalHood"]/statBases</xpath>
		<value>
			<Bulk>2</Bulk>
			<WornBulk>0.5</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="MCO_CoastalHood"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>2.5</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<!-- Coastal scarf -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
			defName = "MCO_CoastalScarf"]/statBases</xpath>
		<value>
			<Bulk>3</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="MCO_CoastalScarf"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>3</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="MCO_CoastalScarf"]/apparel/bodyPartGroups</xpath>
		<value>
			<bodyPartGroups>
				<li>Neck</li>
				<li>Shoulders</li>
			</bodyPartGroups>
		</value>
	</Operation>	

	<!-- Coastal Cape -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
			defName = "MCO_CoastalCape"]/statBases</xpath>
		<value>
			<Bulk>4</Bulk>
			<WornBulk>1.5</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="MCO_CoastalCape"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>3.75</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<!-- Patchwork shirt -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
			defName = "MCO_PatchworkShirt"]/statBases</xpath>
		<value>
			<Bulk>2</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="MCO_PatchworkShirt"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>2</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<!-- Shamanwear -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
			defName = "MCO_Shamanwear"]/statBases</xpath>
		<value>
			<Bulk>5</Bulk>
			<WornBulk>2</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="MCO_Shamanwear"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>4</StuffEffectMultiplierArmor>
		</value>
	</Operation>	

	<!-- Add leg covering because the sprite shows it -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="MCO_Shamanwear"]/apparel/bodyPartGroups</xpath>
		<value>
			<bodyPartGroups>
		        <li>Torso</li>
		        <li>Neck</li>
		        <li>Shoulders</li>
		        <li>Legs</li>
			</bodyPartGroups>
		</value>
	</Operation>

	<!-- simple shirt : slightly better patchwork shirt -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
			defName = "MCO_SimpleShirt"]/statBases</xpath>
		<value>
			<Bulk>2</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="MCO_SimpleShirt"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>2.5</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<!-- Adventurer's outfit : better simple shirt -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
			defName = "MCO_AdventurerOutfit"]/statBases</xpath>
		<value>
			<Bulk>2</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="MCO_AdventurerOutfit"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>3</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<!-- Captain coat : better than parka/duster but bulkier -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
			defName = "MCO_CaptainCoat"]/statBases</xpath>
		<value>
			<Bulk>12</Bulk>
			<WornBulk>6</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="MCO_CaptainCoat"]/statBases</xpath>
		<value>
			<StuffEffectMultiplierArmor>7.5</StuffEffectMultiplierArmor>
		</value>
	</Operation>	

	<Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[defName="MCO_CaptainCoat"]/statBases/ArmorRating_Sharp</xpath>
	</Operation>	

	<Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[defName="MCO_CaptainCoat"]/statBases/ArmorRating_Blunt</xpath>
	</Operation>	

	<Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[defName="MCO_CaptainCoat"]/equippedStatOffsets/MoveSpeed</xpath>
	</Operation>

	<!-- Kiddos stuff -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[
			defName = "MCO_KidRobe" or
			defName = "MCO_KidDress"]/statBases</xpath>
		<value>
			<Bulk>2</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[
			defName = "MCO_KidRobe" or
			defName = "MCO_KidDress"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>2.5</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[
			defName = "MCO_KidRobe" or
			defName = "MCO_KidDress"]/apparel/bodyPartGroups</xpath>
		<value>
			<bodyPartGroups>
		        <li>Torso</li>
		        <li>Neck</li>
		        <li>Shoulders</li>
		        <li>Legs</li>
			</bodyPartGroups>
		</value>
	</Operation>


</Patch>