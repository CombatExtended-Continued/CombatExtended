<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ========== Vacsuit ========== -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="OdysseusVacsuit"]/statBases</xpath>
		<value>
			<Bulk>80</Bulk>
			<WornBulk>20</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="OdysseusVacsuit"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>5</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="OdysseusVacsuit"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>12</ArmorRating_Blunt>
		</value>
	</Operation>

	<!-- ========== Vacsuit Helmet ========== -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="OdysseusVacsuitHelmet"]/statBases</xpath>
		<value>
			<Bulk>4</Bulk>
			<WornBulk>1</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="OdysseusVacsuitHelmet"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>5</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="OdysseusVacsuitHelmet"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>12</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="OdysseusVacsuitHelmet"]/equippedStatOffsets</xpath>
		<value>
			<SmokeSensitivity>-1</SmokeSensitivity>
		</value>
	</Operation>

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/ThingDef[defName="OdysseusVacsuitHelmet"]</xpath>
		<value>
			<li Class="CombatExtended.PartialArmorExt">
				<stats>
					<li>
						<ArmorRating_Sharp>0.70</ArmorRating_Sharp>
						<parts>
							<li>Eye</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.70</ArmorRating_Blunt>
						<parts>
							<li>Eye</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Sharp>0.50</ArmorRating_Sharp>
						<parts>
							<li>Nose</li>
							<li>Jaw</li>
						</parts>
					</li>
					<li>
						<ArmorRating_Blunt>0.50</ArmorRating_Blunt>
						<parts>
							<li>Nose</li>
							<li>Jaw</li>
						</parts>
					</li>
				</stats>
			</li>
		</value>
	</Operation>

</Patch>