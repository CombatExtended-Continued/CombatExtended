<?xml version="1.0" encoding="UTF-8"?>
<Patch>
    <!-- ============================ Hat ============================ -->
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[
            defName="RFNikkeApparel_hat_snowwhite" or
            defName="RFNikkeApparel_hat_rapunzel" or
            defName="RFNikkeApparel_hat_scarlet"
            ]/statBases</xpath>
        <value>
            <Bulk>3</Bulk>
            <WornBulk>1</WornBulk>
            <Flammability>0.5</Flammability>
        </value>
    </Operation>

    <!--Snow White Hat-->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="RFNikkeApparel_hat_snowwhite"]/statBases/ArmorRating_Sharp</xpath>
