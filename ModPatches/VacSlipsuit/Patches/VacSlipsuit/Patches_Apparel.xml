<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ========== VacSlipsuit ========== -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="VacSlipsuit"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>1</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="VacSlipsuit"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>1</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="VacSlipsuit"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<Bulk>15</Bulk>
			<WornBulk>7</WornBulk>
			<StuffEffectMultiplierArmor>2</StuffEffectMultiplierArmor>
		</value>
	</Operation>

</Patch>