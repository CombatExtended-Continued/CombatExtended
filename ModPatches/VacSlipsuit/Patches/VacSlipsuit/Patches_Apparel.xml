<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ========== VacSlipsuit ========== -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="VacSlipsuit"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<Bulk>10</Bulk>
			<WornBulk>5</WornBulk>
			<StuffEffectMultiplierArmor>2</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="VacSlipsuit"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="VacSlipsuit"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>0.65</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VacSlipsuit"]/apparel/bodyPartGroups</xpath>
		<value>
			<li>Hands</li>
			<li>Feet</li>
		</value>
	</Operation>

	<!-- ========== Kid's VacSlipsuit ========== -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="KidVacSlipsuit"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<Bulk>8</Bulk>
			<WornBulk>3</WornBulk>
			<StuffEffectMultiplierArmor>2</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="KidVacSlipsuit"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>0.5</ArmorRating_Sharp>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="KidVacSlipsuit"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>0.65</ArmorRating_Blunt>
		</value>
	</Operation>

</Patch>