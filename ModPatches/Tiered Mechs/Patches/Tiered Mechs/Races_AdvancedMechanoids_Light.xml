<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ========== Light Mechanoid ========== -->

	<Operation Class="PatchOperationConditional">
		<xpath>Defs/ThingDef[defName="Mech_LifterPlus"]/comps</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/ThingDef[defName="Mech_LifterPlus"]</xpath>
			<value>
				<comps />
			</value>
		</nomatch>
	</Operation>

	<Operation Class="PatchOperationConditional">
		<xpath>Defs/ThingDef[defName="Mech_ConstructoidPlus"]/comps</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/ThingDef[defName="Mech_ConstructoidPlus"]</xpath>
			<value>
				<comps />
			</value>
		</nomatch>
	</Operation>

