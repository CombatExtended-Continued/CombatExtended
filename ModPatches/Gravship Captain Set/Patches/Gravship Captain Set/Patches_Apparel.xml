<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ========== Vacsuit ========== -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="GravshipCaptainVacsuit"]/statBases</xpath>
		<value>
			<Bulk>80</Bulk>
			<WornBulk>12</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="GravshipCaptainVacsuit"]/statBases/ArmorRating_Sharp</xpath>
